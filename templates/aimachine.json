et", "widgetType": "text-editor", "settings": {"editor": "<p>54 AI-generated videos built to personalize conversion journeys. Each video adapts messaging to a specific buyer persona, industry, or funnel stage. Built on the EPIC Framework.</p>", "text_color": "rgba(18,37,62,0.65)", "typography_typography": "custom", "typography_font_family": "DM Sans", "typography_font_size": {"unit": "px", "size": 15, "sizes": []}, "typography_line_height": {"unit": "em", "size": 1.65, "sizes": []}, "_padding": {"unit": "px", "top": "0", "right": "0", "bottom": "14", "left": "0", "isLinked": false}}, "elements": []}, {"id": "aim_c4_tags", "elType": "widget", "widgetType": "text-editor", "settings": {"editor": "<div style=\"display:flex;flex-wrap:wrap;gap:6px;margin-bottom:16px\"><span style=\"background:rgba(18,37,62,0.06);border:1px solid rgba(18,37,62,0.12);border-radius:6px;padding:3px 10px;font-size:12px;font-family:'DM Sans',sans-serif;color:rgba(18,37,62,0.6)\">54 videos</span><span style=\"background:rgba(18,37,62,0.06);border:1px solid rgba(18,37,62,0.12);border-radius:6px;padding:3px 10px;font-size:12px;font-family:'DM Sans',sans-serif;color:rgba(18,37,62,0.6)\">EPIC Framework-based</span><span style=\"background:rgba(18,37,62,0.06);border:1px solid rgba(18,37,62,0.12);border-radius:6px;padding:3px 10px;font-size:12px;font-family:'DM Sans',sans-serif;color:rgba(18,37,62,0.6)\">Conversion optimization</span></div>", "_padding": {"unit": "px", "top": "0", "right": "0", "bottom": "0", "left": "0", "isLinked": false}}, "elements": []}, {"id": "aim_c4_link", "elType": "widget", "widgetType": "button", "settings": {"text": "View Portfolio →", "link": {"url": "/portfolio", "is_external": ""}, "align": "left", "button_type": "default", "background_color": "rgba(0,0,0,0)", "button_text_color": "#C0392B", "border_width": {"unit": "px", "top": "0", "right": "0", "bottom": "0", "left": "0", "isLinked": true}, "border_radius": {"unit": "px", "top": "0", "right": "0", "bottom": "0", "left": "0", "isLinked": true}, "typography_typography": "custom", "typography_font_family": "Montserrat", "typography_font_weight": "700", "typography_font_size": {"unit": "px", "size": 12, "sizes": []}, "typography_letter_spacing": {"unit": "px", "size": 1}, "typography_text_transform": "uppercase", "padding": {"unit": "px", "top": "0", "right": "0", "bottom": "0", "left": "0", "isLinked": false}}, "elements": []}]}]}, {"id": "aim_agents_sec", "elType": "section", "isInner": false, "settings": {"background_background": "classic", "background_color": "#F7F7F2", "stretch_section": "section-stretched", "layout": "full_width", "padding": {"unit": "px", "top": "0", "right": "56", "bottom": "80", "left": "56", "isLinked": false}, "content_width": {"unit": "px", "size": 1200}}, "elements": [{"id": "aim_agents_col", "elType": "column", "settings": {"_column_size": 100}, "elements": [{"id": "aim_agents_html", "elType": "widget", "widgetType": "html", "settings": {"html": "<style>\n.ab-board-wrap{background:#fff;border:1px solid rgba(18,37,62,0.08);border-radius:20px;padding:36px;box-shadow:0 2px 16px rgba(18,37,62,0.07)}\n.ab-overline{display:block;font-family:'Montserrat',sans-serif;font-weight:700;font-size:10px;letter-spacing:3px;text-transform:uppercase;color:#C9A84C;margin-bottom:20px}\n.ab-row{display:flex;align-items:center;gap:14px;padding:14px 0;border-bottom:1px solid rgba(18,37,62,0.06)}\n.ab-row:last-child{border-bottom:none}\n.ab-dot-wrap{position:relative;width:12px;height:12px;flex-shrink:0}\n.ab-dot{width:10px;height:10px;background:#22C55E;border-radius:50%;position:absolute;top:1px;left:1px}\n.ab-pulse{width:18px;height:18px;background:rgba(34,197,94,0.25);border-radius:50%;position:absolute;top:-3px;left:-3px;animation:ab-ping 1.8s ease-out infinite}\n@keyframes ab-ping{0%{transform:scale(0.8);opacity:0.7}80%{transform:scale(1.8);opacity:0}100%{transform:scale(0.8);opacity:0}}\n.ab-name{font-family:'Montserrat',sans-serif;font-weight:700;font-size:13px;color:#12253E;min-width:180px}\n.ab-desc{font-family:'DM Sans',sans-serif;font-size:13px;color:rgba(18,37,62,0.55);flex:1}\n.ab-metric{font-family:'Montserrat',sans-serif;font-weight:800;font-size:13px;color:#C9A84C;text-align:right;min-width:90px;transition:opacity 0.2s}\n@media(max-width:640px){.ab-desc{display:none}}\n</style>\n<div class=\"ab-board-wrap\">\n  <span class=\"ab-overline\">AI Agents &mdash; Live Right Now</span>\n  <div id=\"ab-board\"></div>\n</div>\n<script>\n(function(){\n  var agents=[\n    {name:'Pre-Call Intel',desc:'Scanning LinkedIn + news for buyer triggers',metric:'247 accounts',min:200,max:300},\n    {name:'Anonymous Visitor ID',desc:'Identifying unknown visitors to ripmediagroup.com',metric:'12 today',min:8,max:22},\n    {name:'Outbound Personalization',desc:'Generating account-specific opening lines',metric:'89 sent today',min:60,max:120},\n    {name:'Call Transcript Analyzer',desc:'Extracting objection patterns from recordings',metric:'4 analyzed',min:2,max:8},\n    {name:'Market Triggers',desc:'Monitoring funding, hiring, tech stack changes',metric:'33 alerts',min:20,max:50},\n    {name:'Script Timer AI',desc:'Active user sessions right now',metric:'814 users',min:750,max:950}\n  ];\n  var board=document.getElementById('ab-board');\n  if(!board)return;\n  agents.forEach(function(a,i){\n    var row=document.createElement('div');row.className='ab-row';\n    row.innerHTML='<div class=\"ab-dot-wrap\"><div class=\"ab-dot\"></div><div class=\"ab-pulse\"></div></div><div class=\"ab-name\">'+a.name+'</div><div class=\"ab-desc\">'+a.desc+'</div><div class=\"ab-metric\" id=\"ab-m-'+i+'\">'+a.metric+'</div>';\n    board.appendChild(row);\n  });\n  setInterval(function(){\n    agents.forEach(function(a,i){\n      var el=document.getElementById('ab-m-'+i);if(!el)return;\n      el.style.opacity='0';\n      setTimeout(function(){el.textContent=Math.floor(Math.random()*(a.max-a.min)+a.min).toLocaleString();el.style.opacity='1';},200);\n    });\n  },3000);\n})();\n</script>"}, "elements": []}]}]}]}