          "elements": [
            {
              "id": "e2_html",
              "elType": "widget",
              "widgetType": "html",
              "settings": {
                "html": "<link href=\"https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;900&family=DM+Sans:wght@400;500;600&family=DM+Mono:wght@400;500&display=swap\" rel=\"stylesheet\">\n<style>\n*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }\n:root {\n  --navy: #0A1628; --gold: #C9A84C; --red: #C0392B;\n  --offwhite: #F7F7F2; --royal: #1B3A8A; --white: #ffffff;\n}\nbody { background: var(--offwhite); font-family: 'DM Sans', sans-serif; color: var(--navy); overflow-x: hidden; }\n\n/* BANNER */\n.banner { background: var(--navy); padding: 18px 40px; display: flex; align-items: center; justify-content: space-between; }\n.banner-logo { font-family: 'Montserrat', sans-serif; font-weight: 900; font-size: 15px; letter-spacing: 2px; text-transform: uppercase; color: var(--white); }\n.banner-logo span { color: var(--gold); }\n.banner-tagline { font-family: 'DM Mono', monospace; font-size: 10px; letter-spacing: 2px; text-transform: uppercase; color: rgba(255,255,255,0.5); }\n\n/* HERO */\n.hero { background: linear-gradient(160deg, #0A1628 0%, #0d1e3a 30%, #1B3A8A 70%, #0a1f45 100%); padding: 70px 40px 80px; text-align: center; position: relative; overflow: hidden; }\n.hero-pulse { position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%); width: 600px; height: 600px; border-radius: 50%; background: radial-gradient(circle, rgba(192,57,43,0.08) 0%, transparent 65%); pointer-events: none; animation: pulse 4s ease-in-out infinite; }\n@keyframes pulse { 0%,100%{transform:translate(-50%,-50%) scale(1);opacity:.6;} 50%{transform:translate(-50%,-50%) scale(1.15);opacity:1;} }\n.hero > *:not(.hero-pulse) { position: relative; z-index: 1; }\n.hero-eyebrow { font-family: 'DM Mono', monospace; font-size: 10px; letter-spacing: 3px; text-transform: uppercase; color: var(--gold); margin-bottom: 20px; }\n.hero h1 { font-family: 'Montserrat', sans-serif; font-weight: 900; font-size: clamp(32px, 5vw, 56px); line-height: 1.05; color: var(--white); max-width: 780px; margin: 0 auto 16px; }\n.hero h1 em { color: var(--gold); font-style: normal; }\n.hero-sub { font-size: 17px; color: rgba(255,255,255,0.65); max-width: 560px; margin: 0 auto 36px; line-height: 1.6; }\n.hero-cta { display: inline-block; background: var(--red); color: var(--white); font-family: 'Montserrat', sans-serif; font-weight: 700; font-size: 12px; letter-spacing: 1.5px; text-transform: uppercase; padding: 16px 36px; border-radius: 4px; text-decoration: none; transition: opacity 0.2s; }\n.hero-cta:hover { opacity: 0.85; }\n\n/* STAT BAR */\n.stat-bar { background: var(--navy); padding: 40px; }\n.stat-bar-inner { max-width: 960px; margin: 0 auto; display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; text-align: center; }\n.stat-num { font-family: 'Montserrat', sans-serif; font-weight: 900; font-size: 36px; color: var(--gold); line-height: 1; margin-bottom: 6px; }\n.stat-desc { font-size: 12px; color: rgba(255,255,255,0.6); letter-spacing: 0.5px; line-height: 1.4; }\n\n/* SECTION */\n.section { padding: 70px 40px; max-width: 960px; margin: 0 auto; }\n.section-label { font-family: 'DM Mono', monospace; font-size: 10px; letter-spacing: 3px; text-transform: uppercase; color: var(--gold); margin-bottom: 12px; }\n.section h2 { font-family: 'Montserrat', sans-serif; font-weight: 900; font-size: clamp(24px, 3.5vw, 38px); line-height: 1.15; color: var(--navy); margin-bottom: 20px; }\n.section p { font-size: 16px; line-height: 1.7; color: #3a4a60; max-width: 680px; }\n\n/* MACHINE STEPS */\n.steps-section { background: var(--white); padding: 70px 40px; }\n.steps-inner { max-width: 960px; margin: 0 auto; }\n.steps-inner .section-label { color: var(--gold); }\n.steps-inner h2 { font-family: 'Montserrat', sans-serif; font-weight: 900; font-size: clamp(24px,3.5vw,38px); color: var(--navy); margin-bottom: 10px; }\n.steps-intro { font-size: 16px; color: #3a4a60; line-height: 1.7; margin-bottom: 48px; max-width: 680px; }\n.steps-flow { display: flex; flex-direction: column; gap: 0; }\n.step-row { display: grid; grid-template-columns: 60px 1fr; gap: 24px; align-items: start; position: relative; padding-bottom: 40px; }\n.step-row:last-child { padding-bottom: 0; }\n.step-row:not(:last-child)::after { content: ''; position: absolute; left: 29px; top: 56px; bottom: 0; width: 2px; background: linear-gradient(180deg, rgba(201,168,76,0.4), rgba(201,168,76,0.05)); }\n.step-circle { width: 60px; height: 60px; border-radius: 50%; background: var(--navy); border: 2px solid var(--gold); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }\n.step-num { font-family: 'Montserrat', sans-serif; font-weight: 900; font-size: 18px; color: var(--gold); }\n.step-body {}\n.step-label { font-family: 'DM Mono', monospace; font-size: 9px; letter-spacing: 2px; text-transform: uppercase; color: var(--gold); margin-bottom: 4px; }\n.step-title { font-family: 'Montserrat', sans-serif; font-weight: 800; font-size: 18px; color: var(--navy); margin-bottom: 8px; line-height: 1.2; }\n.step-desc { font-size: 14px; color: #5a6a80; line-height: 1.65; max-width: 560px; }\n.step-time { display: inline-block; margin-top: 8px; background: rgba(201,168,76,0.12); border: 1px solid rgba(201,168,76,0.3); border-radius: 4px; padding: 4px 10px; font-family: 'DM Mono', monospace; font-size: 10px; letter-spacing: 1.5px; text-transform: uppercase; color: var(--gold); }\n\n/* COMPARISON TABLE */\n.compare-section { background: var(--offwhite); padding: 70px 40px; }\n.compare-inner { max-width: 820px; margin: 0 auto; }\n.compare-inner .section-label { color: var(--gold); }\n.compare-inner h2 { font-family: 'Montserrat', sans-serif; font-weight: 900; font-size: clamp(24px,3.5vw,36px); color: var(--navy); margin-bottom: 36px; }\n.compare-table { width: 100%; border-collapse: collapse; }\n.compare-table th { font-family: 'Montserrat', sans-serif; font-weight: 700; font-size: 11px; letter-spacing: 1.5px; text-transform: uppercase; padding: 14px 20px; text-align: left; }\n.compare-table th:first-child { color: #8a9ab0; background: transparent; border-radius: 8px 0 0 0; }\n.compare-table th.col-manual { background: rgba(10,22,40,0.06); color: #6a7a90; border-radius: 0; }\n.compare-table th.col-machine { background: var(--navy); color: var(--gold); border-radius: 0 8px 0 0; }\n.compare-table td { padding: 14px 20px; font-size: 14px; border-top: 1px solid rgba(10,22,40,0.07); vertical-align: middle; }\n.compare-table td:first-child { font-weight: 600; color: var(--navy); font-size: 13px; }\n.compare-table td.col-manual { background: rgba(10,22,40,0.03); color: #8a9ab0; }\n.compare-table td.col-machine { background: rgba(10,22,40,0.88); color: rgba(255,255,255,0.85); }\n.compare-table tr:last-child td:last-child { border-radius: 0 0 8px 0; }\n.compare-table tr:last-child td.col-manual { border-radius: 0; }\n.tag-slow { color: #c0392b; font-size: 11px; }\n.tag-fast { color: var(--gold); font-size: 11px; font-weight: 700; }\n\n/* AI TOOLS GRID */\n.tools-section { background: var(--navy); padding: 70px 40px; }\n.tools-inner { max-width: 960px; margin: 0 auto; }\n.tools-label { font-family: 'DM Mono', monospace; font-size: 10px; letter-spacing: 3px; text-transform: uppercase; color: var(--gold); margin-bottom: 12px; }\n.tools-inner h2 { font-family: 'Montserrat', sans-serif; font-weight: 900; font-size: clamp(24px,3.5vw,36px); color: var(--white); margin-bottom: 10px; }\n.tools-sub { font-size: 15px; color: rgba(255,255,255,0.55); margin-bottom: 40px; line-height: 1.6; }\n.tools-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 16px; }\n.tool-card { background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); border-radius: 12px; padding: 24px; transition: border-color 0.2s, background 0.2s; }\n.tool-card:hover { border-color: rgba(201,168,76,0.35); background: rgba(255,255,255,0.07); }\n.tool-icon { font-size: 28px; margin-bottom: 14px; }\n.tool-category { font-family: 'DM Mono', monospace; font-size: 9px; letter-spacing: 2px; text-transform: uppercase; color: rgba(255,255,255,0.35); margin-bottom: 6px; }\n.tool-name { font-family: 'Montserrat', sans-serif; font-weight: 700; font-size: 15px; color: var(--white); margin-bottom: 8px; }\n.tool-desc { font-size: 13px; color: rgba(255,255,255,0.5); line-height: 1.6; }\n.tool-result { margin-top: 12px; font-family: 'Montserrat', sans-serif; font-weight: 700; font-size: 13px; color: var(--gold); }\n\n/* ROI CALCULATOR */\n.roi-section { background: var(--offwhite); padding: 70px 40px; }\n.roi-inner { max-width: 820px; margin: 0 auto; }\n.roi-inner .section-label { color: var(--gold); }\n.roi-inner h2 { font-family: 'Montserrat', sans-serif; font-weight: 900; font-size: clamp(24px,3.5vw,36px); color: var(--navy); margin-bottom: 10px; }\n.roi-sub { font-size: 15px; color: #5a6a80; margin-bottom: 36px; line-height: 1.6; }\n.roi-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 24px; }\n.roi-field label { display: block; font-family: 'DM Mono', monospace; font-size: 10px; letter-spacing: 2px; text-transform: uppercase; color: #8a9ab0; margin-bottom: 10px; }\n.roi-field input { width: 100%; background: var(--white); border: 1px solid rgba(10,22,40,0.15); border-radius: 6px; padding: 14px 16px; font-family: 'Montserrat', sans-serif; font-weight: 700; font-size: 22px; color: var(--navy); outline: none; transition: border-color 0.2s; -moz-appearance: textfield; }\n.roi-field input::-webkit-outer-spin-button, .roi-field input::-webkit-inner-spin-button { -webkit-appearance: none; }\n.roi-field input:focus { border-color: var(--gold); }\n.roi-results { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 16px; margin-top: 10px; }\n.roi-box { background: var(--white); border: 1px solid rgba(10,22,40,0.08); border-radius: 8px; padding: 24px 20px; text-align: center; }\n.roi-box.highlight { background: var(--navy); border-color: var(--navy); }\n.roi-box-label { font-family: 'DM Mono', monospace; font-size: 9px; letter-spacing: 2px; text-transform: uppercase; color: #8a9ab0; margin-bottom: 10px; }\n.roi-box.highlight .roi-box-label { color: rgba(255,255,255,0.45); }\n.roi-box-num { font-family: 'Montserrat', sans-serif; font-weight: 900; font-size: 30px; color: var(--navy); line-height: 1; margin-bottom: 6px; }\n.roi-box.highlight .roi-box-num { color: var(--gold); }\n.roi-box-sub { font-size: 11px; color: #9aabb0; line-height: 1.4; }\n.roi-box.highlight .roi-box-sub { color: rgba(255,255,255,0.35); }\n.roi-note { margin-top: 16px; font-size: 12px; color: #8a9ab0; line-height: 1.6; font-style: italic; }\n\n/* TEASER */\n.teaser-section { background: var(--navy); padding: 70px 40px; text-align: center; position: relative; overflow: hidden; }\n.teaser-section::before { content: ''; position: absolute; bottom: -80px; left: 50%; transform: translateX(-50%); width: 500px; height: 500px; background: radial-gradient(circle, rgba(201,168,76,0.10) 0%, transparent 70%); pointer-events: none; }\n.teaser-inner { max-width: 660px; margin: 0 auto; position: relative; }\n.teaser-eyebrow { font-family: 'DM Mono', monospace; font-size: 10px; letter-spacing: 3px; text-transform: uppercase; color: var(--gold); margin-bottom: 20px; }\n.teaser-inner h2 { font-family: 'Montserrat', sans-serif; font-weight: 900; font-size: clamp(26px,4vw,40px); color: var(--white); line-height: 1.15; margin-bottom: 20px; }\n.teaser-inner h2 em { color: var(--gold); font-style: normal; }\n.teaser-body { font-size: 16px; color: rgba(255,255,255,0.6); line-height: 1.7; margin-bottom: 36px; }\n.teaser-cta { display: inline-block; background: var(--red); color: var(--white); font-family: 'Montserrat', sans-serif; font-weight: 700; font-size: 12px; letter-spacing: 1.5px; text-transform: uppercase; padding: 16px 36px; border-radius: 4px; text-decoration: none; transition: opacity 0.2s; }\n.teaser-cta:hover { opacity: 0.85; }\n.teaser-timer { margin-top: 20px; font-family: 'DM Mono', monospace; font-size: 11px; letter-spacing: 2px; color: rgba(255,255,255,0.3); }\n\n/* FOOTER */\n.footer { background: #060e1a; padding: 30px 40px; display: flex; align-items: center; justify-content: space-between; }\n.footer-logo { font-family: 'Montserrat', sans-serif; font-weight: 900; font-size: 13px; letter-spacing: 2px; text-transform: uppercase; color: rgba(255,255,255,0.4); }\n.footer-logo span { color: var(--gold); }\n.footer-link { font-family: 'DM Mono', monospace; font-size: 10px; letter-spacing: 2px; text-transform: uppercase; color: rgba(255,255,255,0.3); text-decoration: none; }\n.footer-link:hover { color: var(--gold); }\n\n/* ANIMATIONS */\n.fade-in { opacity: 0; transform: translateY(20px); transition: opacity 0.6s ease, transform 0.6s ease; }\n.fade-in.visible { opacity: 1; transform: translateY(0); }\n\n@media (max-width: 700px) {\n  .banner { flex-direction: column; gap: 8px; text-align: center; }\n  .stat-bar-inner { grid-template-columns: repeat(2,1fr); }\n  .step-row { grid-template-columns: 48px 1fr; }\n  .tools-grid { grid-template-columns: 1fr; }\n  .roi-grid { grid-template-columns: 1fr; }\n  .roi-results { grid-template-columns: 1fr; }\n  .compare-table { font-size: 12px; }\n  .footer { flex-direction: column; gap: 12px; text-align: center; }\n}\n</style>\n<!-- BANNER -->\n<div class=\"banner\">\n  <div class=\"banner-logo\">Rip Media <span>Group</span></div>\n  <div class=\"banner-tagline\">Email 2 of 3 &middot; The Machine</div>\n</div>\n\n<!-- HERO -->\n<div class=\"hero\">\n  <div class=\"hero-pulse\"></div>\n  <div class=\"hero-eyebrow\">Email 2 of 3 &middot; Story &middot; Assets &middot; Machine</div>\n  <h1>Your story is clear.<br>Now make it <em>unstoppable.</em></h1>\n  <p class=\"hero-sub\">A great story told once is a conversation. A great story deployed through the right machine is a pipeline. Here is what that looks like in practice.</p>\n  <a href=\"https://ripmediagroup.com/audit\" class=\"hero-cta\">Get Your Free Story Diagnosis</a>\n</div>\n\n<!-- STAT BAR -->\n<div class=\"stat-bar\">\n  <div class=\"stat-bar-inner\">\n    <div class=\"stat-item fade-in\"><div class=\"stat-num\">60s</div><div class=\"stat-desc\">Pre-call research with AI</div></div>\n    <div class=\"stat-item fade-in\"><div class=\"stat-num\">10x</div><div class=\"stat-desc\">More outreach, same headcount</div></div>\n    <div class=\"stat-item fade-in\"><div class=\"stat-num\">24/7</div><div class=\"stat-desc\">Pipeline running while you sleep</div></div>\n    <div class=\"stat-item fade-in\"><div class=\"stat-num\">3.2x</div><div class=\"stat-desc\">Avg pipeline increase in 90 days</div></div>\n  </div>\n</div>\n\n<!-- WHAT THE MACHINE DOES -->\n<div class=\"steps-section\">\n  <div class=\"steps-inner\">\n    <div class=\"section-label\">How the Machine Works</div>\n    <h2>Story in. Pipeline out.<br>Here is the five-step system.</h2>\n    <p class=\"steps-intro\">Every step below runs on the story foundation from Email 1. Without a clear story, the machine amplifies noise. With it, every output compounds.</p>\n\n    <div class=\"steps-flow\">\n      <div class=\"step-row fade-in\">\n        <div class=\"step-circle\"><div class=\"step-num\">01</div></div>\n        <div class=\"step-body\">\n          <div class=\"step-label\">Research</div>\n          <div class=\"step-title\">AI prospect research in under 60 seconds</div>\n          <div class=\"step-desc\">Before any call or email, your rep knows the prospect's last earnings call, recent hires, tech stack, and competitive exposure. Not because they spent two hours on LinkedIn. Because the machine did it overnight.</div>\n          <span class=\"step-time\">Time saved: 90 min per rep per day</span>\n        </div>\n      </div>\n\n      <div class=\"step-row fade-in\">\n        <div class=\"step-circle\"><div class=\"step-num\">02</div></div>\n        <div class=\"step-body\">\n          <div class=\"step-label\">Outreach</div>\n          <div class=\"step-title\">Personalized sequences that actually sound human</div>\n          <div class=\"step-desc\">AI writes the first draft of every outreach email using your story framework and the prospect's specific context. Your reps review and send. The result reads like it was written for that person, because the structure was built for every person.</div>\n          <span class=\"step-time\">Output: 5x sequences at the same quality</span>\n        </div>\n      </div>\n\n      <div class=\"step-row fade-in\">\n        <div class=\"step-circle\"><div class=\"step-num\">03</div></div>\n        <div class=\"step-body\">\n          <div class=\"step-label\">Website</div>\n          <div class=\"step-title\">Pipeline from visitors who never filled out a form</div>\n          <div class=\"step-desc\">Tools like RB2B and Clearbit reveal who is on your site right now — company, name, page visited. Your machine turns anonymous traffic into outbound triggers. Most B2B companies have three to five months of warm pipeline sitting invisibly on their website.</div>\n          <span class=\"step-time\">Avg recovery: 3–5 months of hidden pipeline</span>\n        </div>\n      </div>\n\n      <div class=\"step-row fade-in\">\n        <div class=\"step-circle\"><div class=\"step-num\">04</div></div>\n        <div class=\"step-body\">\n          <div class=\"step-label\">Content</div>\n          <div class=\"step-title\">One idea. Ten assets. Zero extra headcount.</div>\n          <div class=\"step-desc\">A single insight from your Greenlight story becomes a LinkedIn post, a short video script, a one-pager, a nurture email, and a case study outline — all aligned to the same message. Your team is not producing more content. The machine is.</div>\n          <span class=\"step-time\">Content output: 10x with same team size</span>\n        </div>\n      </div>\n\n      <div class=\"step-row fade-in\">\n        <div class=\"step-circle\"><div class=\"step-num\">05</div></div>\n        <div class=\"step-body\">\n          <div class=\"step-label\">Follow-Up</div>\n          <div class=\"step-title\">AI follow-up that never drops a lead</div>\n          <div class=\"step-desc\">Every prospect who goes quiet gets a timed, contextual follow-up. Not a generic \"just checking in\" — a follow-up that references their specific situation and moves them forward. The machine does not forget. It does not get discouraged. It just keeps going.</div>\n          <span class=\"step-time\">Recovery rate: up to 22% of stalled deals</span>\n        </div>\n      </div>\n    </div>\n  </div>\n</div>\n\n<!-- COMPARISON -->\n<div class=\"compare-section\">\n  <div class=\"compare-inner\">\n    <div class=\"section-label\">Manual vs. Machine</div>\n    <h2>Same team. Same story.<br>Completely different output.</h2>\n    <table class=\"compare-table\">\n      <thead>\n        <tr>\n          <th>Task</th>\n          <th class=\"col-manual\">Manual Approach</th>\n          <th class=\"col-machine\">With the Machine</th>\n        </tr>\n      </thead>\n      <tbody>\n        <tr>\n          <td>Pre-call research</td>\n          <td class=\"col-manual\">90 min per prospect <span class=\"tag-slow\">&#9650; Slow</span></td>\n          <td class=\"col-machine\">60 seconds <span class=\"tag-fast\">&#9654; Instant</span></td>\n        </tr>\n        <tr>\n          <td>Outreach sequences</td>\n          <td class=\"col-manual\">1–2 per rep per day</td>\n          <td class=\"col-machine\">10–15 per rep per day <span class=\"tag-fast\">&#9654; 10x</span></td>\n        </tr>\n        <tr>\n          <td>Website visitor follow-up</td>\n          <td class=\"col-manual\">0% captured (anonymous)</td>\n          <td class=\"col-machine\">Named + triggered within 1 hr</td>\n        </tr>\n        <tr>\n          <td>Content production</td>\n          <td class=\"col-manual\">1 asset per week per writer</td>\n          <td class=\"col-machine\">10 assets from 1 input</td>\n        </tr>\n        <tr>\n          <td>Stalled deal follow-up</td>\n          <td class=\"col-manual\">Inconsistent, manual</td>\n          <td class=\"col-machine\">Automated, contextual, 22% recovery</td>\n        </tr>\n        <tr>\n          <td>Pipeline visibility</td>\n          <td class=\"col-manual\">Spreadsheets + memory</td>\n          <td class=\"col-machine\">Real-time signals + alerts</td>\n        </tr>\n      </tbody>\n    </table>\n  </div>\n</div>\n\n<!-- AI TOOLS -->\n<div class=\"tools-section\">\n  <div class=\"tools-inner\">\n    <div class=\"tools-label\">The Stack</div>\n    <h2 style=\"font-family:'Montserrat',sans-serif;font-weight:900;font-size:clamp(24px,3.5vw,36px);color:var(--white);margin-bottom:10px;\">The exact tools inside the Machine</h2>\n    <p class=\"tools-sub\">These are not hypothetical. These are the tools Rip Media deploys for clients. Each one is useless without the story layer underneath it.</p>\n    <div class=\"tools-grid\">\n      <div class=\"tool-card fade-in\">\n        <div class=\"tool-icon\">&#128269;</div>\n        <div class=\"tool-category\">Research</div>\n        <div class=\"tool-name\">Apollo + Clay</div>\n        <div class=\"tool-desc\">Enriches prospect data in real time — job changes, funding rounds, tech stack, intent signals — and feeds it directly into outreach templates.</div>\n        <div class=\"tool-result\">Result: reps show up prepared, not guessing</div>\n      </div>\n      <div class=\"tool-card fade-in\">\n        <div class=\"tool-icon\">&#9993;</div>\n        <div class=\"tool-category\">Outreach</div>\n        <div class=\"tool-name\">Instantly + Smartlead</div>\n        <div class=\"tool-desc\">Runs personalized cold email at scale across multiple inboxes. Story-aligned sequences delivered with proper warm-up and deliverability controls.</div>\n        <div class=\"tool-result\">Result: inbox placement, not spam folder</div>\n      </div>\n      <div class=\"tool-card fade-in\">\n        <div class=\"tool-icon\">&#128200;</div>\n        <div class=\"tool-category\">Website Intelligence</div>\n        <div class=\"tool-name\">RB2B + Clearbit</div>\n        <div class=\"tool-desc\">De-anonymizes B2B website traffic. Reveals who is reading your pricing page, your case studies, your about page — and triggers outreach before they talk to a competitor.</div>\n        <div class=\"tool-result\">Result: pipeline from your existing traffic</div>\n      </div>\n      <div class=\"tool-card fade-in\">\n        <div class=\"tool-icon\">&#127775;</div>\n        <div class=\"tool-category\">Content Engine</div>\n        <div class=\"tool-name\">Claude + Custom GPTs</div>\n        <div class=\"tool-desc\">Trained on your Greenlight story, these models draft aligned posts, scripts, emails, and one-pagers. Every output sounds like your brand because it was built on your story.</div>\n        <div class=\"tool-result\">Result: consistent voice at 10x output</div>\n      </div>\n      <div class=\"tool-card fade-in\">\n        <div class=\"tool-icon\">&#128247;</div>\n        <div class=\"tool-category\">Video at Scale</div>\n        <div class=\"tool-name\">HeyGen + Descript</div>\n        <div class=\"tool-desc\">Personalized video outreach and content production without a studio. One recorded session becomes dozens of tailored prospect videos or repurposed clips.</div>\n        <div class=\"tool-result\">Result: video pipeline without video overhead</div>\n      </div>\n      <div class=\"tool-card fade-in\">\n        <div class=\"tool-icon\">&#128279;</div>\n        <div class=\"tool-category\">CRM Automation</div>\n        <div class=\"tool-name\">HubSpot + Make</div>\n        <div class=\"tool-desc\">Connects every tool in the stack into a single workflow. Lead scores, follow-up triggers, handoff alerts, and pipeline reporting — automated and visible in one dashboard.</div>\n        <div class=\"tool-result\">Result: nothing falls through the cracks</div>\n      </div>\n    </div>\n  </div>\n</div>\n\n<!-- ROI CALCULATOR -->\n<div class=\"roi-section\">\n  <div class=\"roi-inner\">\n    <div class=\"section-label\">Machine ROI Calculator</div>\n    <h2>What does the Machine return?</h2>\n    <p class=\"roi-sub\">Enter your current numbers. See what a 10x output multiplier does to your pipeline.</p>\n    <div class=\"roi-grid\">\n      <div class=\"roi-field\">\n        <label>Reps on Your Team</label>\n        <input type=\"number\" id=\"repCount\" value=\"5\" min=\"1\" step=\"1\">\n      </div>\n      <div class=\"roi-field\">\n        <label>Outreach per Rep / Day (current)</label>\n        <input type=\"number\" id=\"outreachPerRep\" value=\"20\" min=\"1\" step=\"5\">\n      </div>\n      <div class=\"roi-field\">\n        <label>Average Deal Size ($)</label>\n        <input type=\"number\" id=\"roiDeal\" value=\"25000\" min=\"1000\" step=\"1000\">\n      </div>\n      <div class=\"roi-field\">\n        <label>Current Reply Rate (%)</label>\n        <input type=\"number\" id=\"replyRate\" value=\"3\" min=\"1\" max=\"50\" step=\"1\">\n      </div>\n    </div>\n    <div class=\"roi-results\">\n      <div class=\"roi-box fade-in\">\n        <div class=\"roi-box-label\">Current Monthly Replies</div>\n        <div class=\"roi-box-num\" id=\"roi-current\">90</div>\n        <div class=\"roi-box-sub\">From current outreach volume</div>\n      </div>\n      <div class=\"roi-box highlight fade-in\">\n        <div class=\"roi-box-label\">Machine Monthly Replies</div>\n        <div class=\"roi-box-num\" id=\"roi-machine\">450</div>\n        <div class=\"roi-box-sub\">At 5x outreach, same reply rate</div>\n      </div>\n      <div class=\"roi-box fade-in\">\n        <div class=\"roi-box-label\">Added Pipeline / Month</div>\n        <div class=\"roi-box-num\" id=\"roi-pipeline\">$270K</div>\n        <div class=\"roi-box-sub\">Assuming 10% reply-to-opp conversion</div>\n      </div>\n    </div>\n    <p class=\"roi-note\">* Uses a conservative 5x outreach multiplier (the Machine typically delivers 8–12x for trained teams). Does not account for website visitor recovery or content-driven inbound.</p>\n  </div>\n</div>\n\n<!-- TEASER -->\n<div class=\"teaser-section\">\n  <div class=\"teaser-inner\">\n    <div class=\"teaser-eyebrow\">Coming Saturday &middot; Email 3 of 3</div>\n    <h2>Story. Assets. Machine.<br>Here is how they <em>compound.</em></h2>\n    <p class=\"teaser-body\">In the final email, I will show you what happens when a B2B team runs all three together. The story attracts. The assets convert. The machine scales. That is the Greenlight Process — and we have run it for 400+ companies. Saturday I will show you the full picture.</p>\n    <a href=\"https://ripmediagroup.com/audit\" class=\"teaser-cta\">Reserve Your Diagnosis Slot Now</a>\n    <div class=\"teaser-timer\">Email 3 arrives Saturday &middot; Limited to 8 diagnoses per month</div>\n  </div>\n</div>\n\n<!-- FOOTER -->\n<div class=\"footer\">\n  <div class=\"footer-logo\">Rip Media <span>Group</span> &middot; Maury Rogow</div>\n  <a href=\"https://ripmediagroup.com/audit\" class=\"footer-link\">ripmediagroup.com/audit</a>\n</div>\n\n<script>\n// ROI CALCULATOR\nfunction fmtNum(n) { return n >= 1000 ? '$' + Math.round(n/1000) + 'K' : Math.round(n).toString(); }\nfunction roiUpdate() {\n  var reps = parseFloat(document.getElementById('repCount').value) || 5;\n  var outreach = parseFloat(document.getElementById('outreachPerRep').value) || 20;\n  var deal = parseFloat(document.getElementById('roiDeal').value) || 25000;\n  var reply = parseFloat(document.getElementById('replyRate').value) || 3;\n  var workdays = 22;\n  var currentReplies = Math.round(reps * outreach * workdays * (reply / 100));\n  var machineReplies = Math.round(currentReplies * 5);\n  var addedReplies = machineReplies - currentReplies;\n  var pipeline = addedReplies * 0.10 * deal;\n  document.getElementById('roi-current').textContent = currentReplies.toLocaleString();\n  document.getElementById('roi-machine').textContent = machineReplies.toLocaleString();\n  document.getElementById('roi-pipeline').textContent = fmtNum(pipeline);\n}\n['repCount','outreachPerRep','roiDeal','replyRate'].forEach(function(id) {\n  document.getElementById(id).addEventListener('input', roiUpdate);\n});\nroiUpdate();\n\n// FADE IN\nvar observer = new IntersectionObserver(function(entries) {\n  entries.forEach(function(e) {\n    if (e.isIntersecting) { e.target.classList.add('visible'); observer.unobserve(e.target); }\n  });\n}, { threshold: 0.1 });\ndocument.querySelectorAll('.fade-in').forEach(function(el) { observer.observe(el); });\n</script>"
              },
              "elements": []
            }
          ]
        }
      ]
    }
