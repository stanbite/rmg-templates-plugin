{
  "version": "0.4",
  "title": "Maury CMO Trust Bar",
  "type": "section",
  "page_settings": {},
  "content": [
    {
      "id": "tb_sec",
      "elType": "section",
      "isInner": false,
      "settings": {
        "background_background": "classic",
        "background_color": "#0D1A2E",
        "stretch_section": "section-stretched",
        "layout": "full_width",
        "gap": "no",
        "padding": {
          "unit": "px",
          "top": "0",
          "right": "0",
          "bottom": "0",
          "left": "0",
          "isLinked": true
        },
        "border_border": "solid",
        "border_width": {
          "unit": "px",
          "top": "1",
          "right": "0",
          "bottom": "1",
          "left": "0",
          "isLinked": false
        },
        "border_color": "rgba(255,255,255,0.07)",
        "custom_css": "selector{overflow:hidden;position:relative;} selector::before{content:'';position:absolute;left:0;top:0;bottom:0;width:80px;background:linear-gradient(90deg,#0D1A2E,transparent);z-index:2;pointer-events:none;} selector::after{content:'';position:absolute;right:0;top:0;bottom:0;width:80px;background:linear-gradient(270deg,#0D1A2E,transparent);z-index:2;pointer-events:none;}"
      },
