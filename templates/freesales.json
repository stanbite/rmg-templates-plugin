{"version": "0.4", "title": "freesales", "type": "section", "content": [{"id": "fs_header_sec", "elType": "section", "isInner": false, "settings": {"background_background": "classic", "background_color": "#0A1628", "stretch_section": "section-stretched", "layout": "full_width", "padding": {"unit": "px", "top": "80", "right": "56", "bottom": "40", "left": "56", "isLinked": false}, "content_width": {"unit": "px", "size": 1200}}, "elements": [{"id": "fs_header_col", "elType": "column", "settings": {"_column_size": 100}, "elements": [{"id": "fs_overline", "elType": "widget", "widgetType": "heading", "settings": {"title": "Free Sales Message Diagnosis", "header_size": "h6", "align": "left", "title_color": "#C9A84C", "typography_typography": "custom", "typography_font_family": "Montserrat", "typography_font_weight": "700", "typography_font_size": {"unit": "px", "size": 10, "sizes": []}, "typography_letter_spacing": {"unit": "px", "size": 3}, "typography_text_transform": "uppercase", "_padding": {"unit": "px", "top": "0", "right": "0", "bottom": "16", "left": "0", "isLinked": false}}, "elements": []}, {"id": "fs_heading", "elType": "widget", "widgetType": "heading", "settings": {"title": "Find out exactly where your story is breaking.", "header_size": "h2", "align": "left", "title_color": "#FFFFFF", "typography_typography": "custom", "typography_font_family": "Montserrat", "typography_font_weight": "800", "typography_font_size": {"unit": "vw", "size": 3.4, "sizes": []}, "typography_line_height": {"unit": "em", "size": 1.15, "sizes": []}, "typography_letter_spacing": {"unit": "px", "size": -0.5}, "_padding": {"unit": "px", "top": "0", "right": "0", "bottom": "18", "left": "0", "isLinked": false}}, "elements": []}, {"id": "fs_subtitle", "elType": "widget", "widgetType": "text-editor", "settings": {"editor": "<p>In 90 seconds you'll know which part of your story is broken. Story, Assets, or the AI Machine. For a deeper in-person analysis, book a free 30-minute call.</p>", "text_color": "#FFFFFF", "typography_typography": "custom", "typography_font_family": "DM Sans", "typography_font_weight": "500", "typography_font_size": {"unit": "px", "size": 19, "sizes": []}, "typography_line_height": {"unit": "em", "size": 1.65, "sizes": []}, "_padding": {"unit": "px", "top": "0", "right": "0", "bottom": "0", "left": "0", "isLinked": false}}, "elements": []}]}]}, {"id": "fs_body_sec", "elType": "section", "isInner": false, "settings": {"background_background": "classic", "background_color": "#0A1628", "stretch_section": "section-stretched", "layout": "full_width", "gap": "custom", "gap_columns_custom": {"unit": "px", "size": 48}, "padding": {"unit": "px", "top": "40", "right": "56", "bottom": "80", "left": "56", "isLinked": false}, "content_width": {"unit": "px", "size": 1200}}, "elements": [{"id": "fs_left_col", "elType": "column", "settings": {"_column_size": 50, "align": "top"}, "elements": [{"id": "fs_badge", "elType": "widget", "widgetType": "text-editor", "settings": {"editor": "<div style=\"display:inline-block;border:1px solid rgba(201,168,76,0.4);border-radius:6px;padding:7px 18px;font-family:'Montserrat',sans-serif;font-weight:700;font-size:11px;letter-spacing:2px;text-transform:uppercase;color:#C9A84C;margin-bottom:28px\">Limited to 8 per month</div>", "_padding": {"unit": "px", "top": "0", "right": "0", "bottom": "0", "left": "0", "isLinked": false}}, "elements": []}, {"id": "fs_checklist", "elType": "widget", "widgetType": "text-editor", "settings": {"editor": "<ul style=\"list-style:none;padding:0;margin:0 0 28px 0\">\n<li style=\"display:flex;align-items:flex-start;gap:12px;padding:10px 0;border-bottom:1px solid rgba(255,255,255,0.06);font-family:'DM Sans',sans-serif;font-size:16px;color:#FFFFFF;line-height:1.5\"><span style=\"color:#C9A84C;font-size:16px;flex-shrink:0;margin-top:2px\">✓</span>Story clarity score across 5 dimensions</li>\n<li style=\"display:flex;align-items:flex-start;gap:12px;padding:10px 0;border-bottom:1px solid rgba(255,255,255,0.06);font-family:'DM Sans',sans-serif;font-size:16px;color:#FFFFFF;line-height:1.5\"><span style=\"color:#C9A84C;font-size:16px;flex-shrink:0;margin-top:2px\">✓</span>Where buyers are losing the thread</li>\n<li style=\"display:flex;align-items:flex-start;gap:12px;padding:10px 0;border-bottom:1px solid rgba(255,255,255,0.06);font-family:'DM Sans',sans-serif;font-size:16px;color:#FFFFFF;line-height:1.5\"><span style=\"color:#C9A84C;font-size:16px;flex-shrink:0;margin-top:2px\">✓</span>Competitive language audit</li>\n<li style=\"display:flex;align-items:flex-start;gap:12px;padding:10px 0;border-bottom:1px solid rgba(255,255,255,0.06);font-family:'DM Sans',sans-serif;font-size:16px;color:#FFFFFF;line-height:1.5\"><span style=\"color:#C9A84C;font-size:16px;flex-shrink:0;margin-top:2px\">✓</span>The one message shift most likely to move your close rate</li>\n<li style=\"display:flex;align-items:flex-start;gap:12px;padding:10px 0;font-family:'DM Sans',sans-serif;font-size:16px;color:#FFFFFF;line-height:1.5\"><span style=\"color:#C9A84C;font-size:16px;flex-shrink:0;margin-top:2px\">✓</span>Recommended next step in SAM</li>\n</ul>", "_padding": {"unit": "px", "top": "0", "right": "0", "bottom": "0", "left": "0", "isLinked": false}}, "elements": []}, {"id": "fs_disclaimer", "elType": "widget", "widgetType": "text-editor", "settings": {"editor": "<p style=\"font-style:italic\">No pitch. No obligation. 90 seconds to your diagnosis — or book the free 30-minute call for a deeper look.</p>", "text_color": "rgba(255,255,255,0.45)", "typography_typography": "custom", "typography_font_family": "DM Sans", "typography_font_size": {"unit": "px", "size": 14, "sizes": []}, "typography_line_height": {"unit": "em", "size": 1.6, "sizes": []}}, "elements": []}]}, {"id": "fs_right_col", "elType": "column", "settings": {"_column_size": 50, "align": "top"}, "elements": [{"id": "fs_quiz_html", "elType": "widget", "widgetType": "html", "settings": {"html": "<style>\n.sq2-wrap{background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.1);border-radius:20px;padding:36px;box-shadow:0 12px 48px rgba(0,0,0,0.5)}\n.sq2-progress{display:flex;gap:8px;margin-bottom:28px}\n.sq2-dot{width:12px;height:12px;border-radius:50%;background:rgba(255,255,255,0.15);transition:background 0.3s}\n.sq2-dot.done{background:#C9A84C}\n.sq2-dot.current{background:#FFFFFF}\n.sq2-q{font-family:'Montserrat',sans-serif;font-weight:700;font-size:18px;color:#FFFFFF;line-height:1.4;margin-bottom:20px}\n.sq2-options{display:flex;flex-direction:column;gap:10px}\n.sq2-option{background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.12);border-radius:10px;padding:14px 18px;font-family:'DM Sans',sans-serif;font-size:15px;color:rgba(255,255,255,0.85);text-align:left;cursor:pointer;transition:all 0.2s}\n.sq2-option:hover{background:rgba(201,168,76,0.12);border-color:rgba(201,168,76,0.4);color:#FFFFFF}\n.sq2-gate{display:none;margin-top:8px}\n.sq2-gate h3{font-family:'Montserrat',sans-serif;font-weight:700;font-size:20px;color:#FFFFFF;margin-bottom:10px}\n.sq2-gate p{font-family:'DM Sans',sans-serif;font-size:15px;color:rgba(255,255,255,0.65);margin-bottom:20px;line-height:1.6}\n.sq2-field{width:100%;background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.15);border-radius:8px;padding:13px 16px;color:#FFFFFF;font-family:'DM Sans',sans-serif;font-size:15px;margin-bottom:10px;outline:none;box-sizing:border-box}\n.sq2-field::placeholder{color:rgba(255,255,255,0.35)}\n.sq2-field:focus{border-color:rgba(201,168,76,0.5)}\n.sq2-submit-btn{width:100%;background:#C0392B;color:#FFFFFF;border:none;border-radius:10px;padding:16px 24px;font-family:'Montserrat',sans-serif;font-weight:700;font-size:13px;letter-spacing:1.5px;text-transform:uppercase;cursor:pointer;margin-top:8px;transition:background 0.2s}\n.sq2-submit-btn:hover{background:#a93226}\n.sq2-result{display:none;text-align:center}\n.sq2-result-overline{font-family:'Montserrat',sans-serif;font-weight:700;font-size:10px;letter-spacing:3px;text-transform:uppercase;color:#C9A84C;margin-bottom:16px;display:block}\n.sq2-broken{font-family:'Montserrat',sans-serif;font-weight:900;font-size:96px;color:#C9A84C;line-height:1;margin-bottom:8px}\n.sq2-result h3{font-family:'Montserrat',sans-serif;font-weight:700;font-size:20px;color:#FFFFFF;margin-bottom:16px}\n.sq2-fixes{list-style:none;padding:0;margin:0 0 20px 0;text-align:left}\n.sq2-fixes li{font-family:'DM Sans',sans-serif;font-size:14px;color:rgba(255,255,255,0.75);padding:8px 0;border-bottom:1px solid rgba(255,255,255,0.07);padding-left:20px;position:relative;line-height:1.5}\n.sq2-fixes li::before{content:'→';position:absolute;left:0;color:#C9A84C}\n.sq2-cta-btn{display:block;width:100%;background:#C0392B;color:#FFFFFF;border:none;border-radius:10px;padding:16px 24px;font-family:'Montserrat',sans-serif;font-weight:700;font-size:13px;letter-spacing:1.5px;text-transform:uppercase;cursor:pointer;text-align:center;text-decoration:none;box-sizing:border-box;margin-top:16px;transition:background 0.2s}\n.sq2-cta-btn:hover{background:#a93226;color:#FFFFFF}\n</style>\n<div class=\"sq2-wrap\" id=\"sq2-wrap\">\n  <div id=\"sq2-progress-wrap\" class=\"sq2-progress\"></div>\n  <div id=\"sq2-question-area\"></div>\n  <div id=\"sq2-gate\" class=\"sq2-gate\">\n    <h3>Get Your SAM Diagnosis</h3>\n    <p>Enter your details to see which part of SAM is broken and your five specific fixes.</p>\n    <input type=\"text\" class=\"sq2-field\" id=\"sq2-name\" placeholder=\"Your name\">\n    <input type=\"email\" class=\"sq2-field\" id=\"sq2-email\" placeholder=\"Work email\">\n    <input type=\"text\" class=\"sq2-field\" id=\"sq2-company\" placeholder=\"Company\">\n    <button class=\"sq2-submit-btn\" onclick=\"sq2Submit()\">Get My Diagnosis</button>\n  </div>\n  <div id=\"sq2-result\" class=\"sq2-result\">\n    <span class=\"sq2-result-overline\">Your SAM Diagnosis</span>\n    <div id=\"sq2-broken-letter\" class=\"sq2-broken\">S</div>\n    <h3 id=\"sq2-result-title\"></h3>\n    <ul class=\"sq2-fixes\" id=\"sq2-fixes\"></ul>\n    <a href=\"/audit\" class=\"sq2-cta-btn\">Book Your Free 30-Minute Deep Dive</a>\n  </div>\n</div>\n<script>\n(function(){\n  var questions=[\n    {q:'When you describe your company to a new prospect, how consistent is the message?',opts:['Every rep says it differently','Similar but not exact','Consistent but not compelling','Consistent and buyers get it immediately']},\n    {q:'After demos or presentations, how often do buyers ask \"how is this different from X?\"',opts:['Almost always','Usually','Sometimes','Rarely — they already know']},\n    {q:'What is your primary content for sales conversations?',opts:['Mostly improvised','Slide deck we made internally','Professional deck, but not updated','Video + story-first content that we refresh regularly']},\n    {q:'How would you describe your pipeline automation?',opts:['Mostly manual, some tools','Tools but generic messaging','Automated but low response rates','Story-first automation with good conversion']},\n    {q:'When a deal goes cold, what\\'s usually the reason?',opts:['Buyer went silent — unclear why','Price was the objection','Went with a competitor','We close most of what we start']}\n  ];\n  var diagnoses={\n    S:{title:'Your Story is the broken link.',fixes:['Rewrite your hero message around buyer pain, not product features','Score your site with the SDI — most B2B companies are 38–62','Run the EPIC Framework on your top 3 talking points','Identify the one differentiator your best customers actually repeat','Fix the message before touching the assets or the machine']},\n    A:{title:'Your Assets aren\\'t carrying the Story.',fixes:['Audit every piece of sales content — does it tell a story or list features?','Replace your slide deck opener with the buyer problem, not your company history','Add one brand film that shows the outcome, not the process','Build a leave-behind that reps actually use in follow-ups','Align every asset to one consistent narrative thread']},\n    M:{title:'Your Machine is running on a broken Story.',fixes:['Pause your current sequences and audit the message first','Personalize outbound at the account level, not just the name','Add trigger-based outreach for funding, hiring, and tech stack changes','Build call transcript analysis into your review process','Story-first automation outperforms generic sequences 3x — fix the Story first']}\n  };\n  var answers=[];var curQ=0;\n  function buildProgress(){\n    var wrap=document.getElementById('sq2-progress-wrap');if(!wrap)return;\n    wrap.innerHTML='';\n    questions.forEach(function(_,i){\n      var d=document.createElement('div');\n      d.className='sq2-dot'+(i<curQ?' done':i===curQ?' current':'');\n      wrap.appendChild(d);\n    });\n  }\n  function showQ(){\n    if(curQ>=questions.length){\n      document.getElementById('sq2-question-area').innerHTML='';\n      document.getElementById('sq2-gate').style.display='block';\n      document.getElementById('sq2-progress-wrap').innerHTML='';\n      return;\n    }\n    var q=questions[curQ];\n    var area=document.getElementById('sq2-question-area');\n    area.innerHTML='<div class=\"sq2-q\">'+q.q+'</div><div class=\"sq2-options\">'+\n      q.opts.map(function(o,i){return'<button class=\"sq2-option\" onclick=\"sq2Answer('+i+')\">'+o+'</button>';}).join('')+\n    '</div>';\n    buildProgress();\n  }\n  window.sq2Answer=function(i){answers.push(i);curQ++;showQ();};\n  window.sq2Submit=function(){\n    var email=document.getElementById('sq2-email').value.trim();if(!email)return;\n    var broken='S';\n    if(answers[3]<=1)broken='M';\n    else if(answers[2]<=1)broken='A';\n    var diag=diagnoses[broken];\n    document.getElementById('sq2-gate').style.display='none';\n    var result=document.getElementById('sq2-result');\n    result.style.display='block';\n    document.getElementById('sq2-broken-letter').textContent=broken;\n    document.getElementById('sq2-result-title').textContent=diag.title;\n    var ul=document.getElementById('sq2-fixes');ul.innerHTML='';\n    diag.fixes.forEach(function(f){var li=document.createElement('li');li.textContent=f;ul.appendChild(li);});\n  };\n  showQ();\n})();\n</script>"}, "elements": []}]}]}]}