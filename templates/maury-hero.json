      "settings": {
        "background_background": "gradient",
        "background_color": "#0A1628",
        "background_color_b": "#1B3A8A",
        "background_gradient_angle": { "unit": "deg", "size": 135 },
        "background_gradient_type": "linear",
        "stretch_section": "section-stretched",
        "layout": "full_width",
        "gap": "no",
        "height": "min-height",
        "custom_height": { "unit": "vh", "size": 88 },
        "column_position": "middle",
        "padding": { "unit": "px", "top": "96", "right": "40", "bottom": "96", "left": "40", "isLinked": false },
        "padding_tablet": { "unit": "px", "top": "72", "right": "24", "bottom": "72", "left": "24", "isLinked": false },
        "padding_mobile": { "unit": "px", "top": "64", "right": "20", "bottom": "64", "left": "20", "isLinked": false },
        "content_width": { "unit": "px", "size": 1200 },
        "custom_css": "selector{position:relative;overflow:hidden;} selector::before{content:'';position:absolute;width:500px;height:500px;top:-100px;left:-80px;background:radial-gradient(circle,rgba(201,168,76,.18),transparent 70%);border-radius:50%;filter:blur(90px);pointer-events:none;z-index:0;} selector::after{content:'';position:absolute;width:600px;height:600px;bottom:-200px;right:-100px;background:radial-gradient(circle,rgba(27,58,138,.4),transparent 70%);border-radius:50%;filter:blur(90px);pointer-events:none;z-index:0;} selector .elementor-container{position:relative;z-index:1;background-image:radial-gradient(circle,rgba(201,168,76,.1) 1px,transparent 1px);background-size:28px 28px;-webkit-mask-image:radial-gradient(ellipse 80% 80% at 65% 50%,black 30%,transparent 100%);mask-image:radial-gradient(ellipse 80% 80% at 65% 50%,black 30%,transparent 100%);}"
      },
      "elements": [

        {
