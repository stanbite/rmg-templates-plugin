                "title": "Your buyers are confused.<br><span style=\"color:#C9A84C\">That\u2019s why they say no.</span>",
                "header_size": "h1",
                "align": "left",
                "title_color": "#ffffff",
                "typography_typography": "custom",
                "typography_font_family": "Montserrat",
                "typography_font_weight": "800",
                "typography_font_size": { "unit": "vw", "size": 4.5 },
                "typography_font_size_tablet": { "unit": "px", "size": 44 },
                "typography_font_size_mobile": { "unit": "px", "size": 36 },
                "typography_line_height": { "unit": "em", "size": 1.06 },
                "typography_letter_spacing": { "unit": "em", "size": -0.03 },
                "_padding": { "unit": "px", "top": "0", "right": "0", "bottom": "0", "left": "0", "isLinked": true }
              },
              "elements": []
            },

            {
              "id": "mh_divider",
              "elType": "widget",
