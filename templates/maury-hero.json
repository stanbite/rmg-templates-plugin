                        "typography_letter_spacing": { "unit": "px", "size": 1.5 },
                        "typography_text_transform": "uppercase",
                        "custom_css": "selector .elementor-button{box-shadow:rgba(0,0,0,0) 0 84px 24px,rgba(0,0,0,.01) 0 54px 22px,rgba(0,0,0,.04) 0 30px 18px,rgba(0,0,0,.08) 0 13px 13px,rgba(0,0,0,.09) 0 3px 7px,0 0 24px rgba(192,57,43,.3);transition:transform .25s cubic-bezier(.19,1,.22,1),box-shadow .25s,background-color .2s;position:relative;overflow:hidden;white-space:nowrap;} selector .elementor-button:hover{background-color:#a83225 !important;color:#fff !important;transform:translateY(-5px);box-shadow:rgba(0,0,0,0) 0 96px 28px,rgba(0,0,0,.02) 0 62px 26px,rgba(0,0,0,.06) 0 36px 22px,rgba(0,0,0,.12) 0 16px 16px,rgba(0,0,0,.14) 0 4px 10px,0 0 36px rgba(192,57,43,.45);} selector .elementor-button::after{content:'';position:absolute;top:0;left:-100%;width:60%;height:100%;background:linear-gradient(90deg,transparent,rgba(255,255,255,.15),transparent);transition:left .45s ease;pointer-events:none;} selector .elementor-button:hover::after{left:160%;}"
                      },
                      "elements": []
                    }
                  ]
