            "padding_tablet": { "unit": "px", "top": "0", "right": "0", "bottom": "40", "left": "0", "isLinked": false }
          },
          "elements": [

            {
              "id": "mh_overline",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "For B2B Leaders Who Are Done Guessing",
                "header_size": "h6",
                "align": "left",
                "title_color": "#C9A84C",
                "typography_typography": "custom",
                "typography_font_family": "Montserrat",
                "typography_font_weight": "700",
                "typography_font_size": { "unit": "px", "size": 11 },
                "typography_letter_spacing": { "unit": "px", "size": 2.5 },
                "typography_text_transform": "uppercase",
                "_padding": { "unit": "px", "top": "0", "right": "0", "bottom": "20", "left": "0", "isLinked": false },
                "custom_css": "selector .elementor-heading-title{display:flex;align-items:center;gap:8px;} selector .elementor-heading-title::before{content:'';display:inline-block;width:6px;height:6px;border-radius:50%;background:#C9A84C;flex-shrink:0;}"
              },
              "elements": []
            },

            {
              "id": "mh_h1",
              "elType": "widget",
              "widgetType": "heading",
