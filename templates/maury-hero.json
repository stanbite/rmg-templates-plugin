                    {
                      "id": "mh_btn_gold",
                      "elType": "widget",
                      "widgetType": "button",
                      "settings": {
                        "text": "SEE HOW IT WORKS",
                        "link": { "url": "/services/", "is_external": false, "nofollow": false },
                        "align": "left",
                        "background_color": "rgba(0,0,0,0)",
                        "button_text_color": "#C9A84C",
                        "border_border": "solid",
                        "border_width": { "unit": "px", "top": "1", "right": "1", "bottom": "1", "left": "1", "isLinked": true },
                        "border_color": "#C9A84C",
                        "border_radius": { "unit": "px", "top": "50", "right": "50", "bottom": "50", "left": "50", "isLinked": true },
                        "text_padding": { "unit": "px", "top": "12", "right": "22", "bottom": "12", "left": "22", "isLinked": false },
                        "typography_typography": "custom",
                        "typography_font_family": "Montserrat",
                        "typography_font_weight": "700",
                        "typography_font_size": { "unit": "px", "size": 11 },
                        "typography_letter_spacing": { "unit": "px", "size": 1.5 },
                        "typography_text_transform": "uppercase",
