          "elements": [
            {
              "id": "mh_image",
              "elType": "widget",
              "widgetType": "image",
              "settings": {
                "image": { "url": "", "id": "", "alt": "" },
                "image_size": "full",
                "align": "center",
                "caption_source": "none",
                "custom_css": "selector{position:relative;} selector .elementor-image img{border-radius:20px;border:1px solid rgba(201,168,76,.18);box-shadow:rgba(0,0,0,0) 0 84px 24px,rgba(0,0,0,.01) 0 54px 22px,rgba(0,0,0,.04) 0 30px 18px,rgba(0,0,0,.08) 0 13px 13px,rgba(0,0,0,.09) 0 3px 7px;display:block;width:100%;} selector::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,#C9A84C,#C0392B);border-radius:20px 20px 0 0;z-index:1;pointer-events:none;}"
              },
              "elements": []
            }
          ]
        }

