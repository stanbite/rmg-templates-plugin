        "background_color": "#0A1628",
        "background_color_b": "#1B3A8A",
        "background_gradient_angle": { "unit": "deg", "size": 135 },
        "background_gradient_type": "linear",
        "stretch_section": "section-stretched",
        "layout": "full_width",
        "gap": "no",
        "height": "min-height",
        "custom_height": { "unit": "vh", "size": 88 },
        "column_position": "middle",
        "padding": { "unit": "px", "top": "80", "right": "40", "bottom": "80", "left": "40", "isLinked": false },
        "padding_tablet": { "unit": "px", "top": "64", "right": "24", "bottom": "64", "left": "24", "isLinked": false },
        "padding_mobile": { "unit": "px", "top": "56", "right": "20", "bottom": "56", "left": "20", "isLinked": false },
        "content_width": { "unit": "px", "size": 1200 },
