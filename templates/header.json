{"version": "0.4", "title": "header", "type": "section", "page_settings": {}, "content": [{"id": "hdr_outer_sec", "elType": "section", "isInner": false, "settings": {"background_background": "classic", "background_color": "rgba(10,22,40,0.97)", "stretch_section": "section-stretched", "layout": "full_width", "gap": "no", "padding": {"unit": "px", "top": "0", "right": "0", "bottom": "0", "left": "0", "isLinked": true}, "content_width": {"unit": "px", "size": 1400}}, "elements": [{"id": "hdr_col", "elType": "column", "settings": {"_column_size": 100, "padding": {"unit": "px", "top": "0", "right": "0", "bottom": "0", "left": "0", "isLinked": true}}, "elements": [{"id": "hdr_html", "elType": "widget", "widgetType": "html", "settings": {"html": "<style>\n.rmhdr *,.rmhdr *::before,.rmhdr *::after{box-sizing:border-box;margin:0;padding:0}\n.rmhdr{\n  width:100%;\n  background:rgba(10,22,40,0.97);\n  border-bottom:1px solid rgba(201,168,76,0.25);\n  height:68px;\n  display:flex;\n  align-items:center;\n  font-family:'Montserrat',sans-serif;\n  position:relative;\n  z-index:999;\n}\n.rmhdr-in{\n  max-width:1200px;\n  margin:0 auto;\n  width:100%;\n  padding:0 24px;\n  display:flex;\n  align-items:center;\n  justify-content:space-between;\n  gap:24px;\n}\n.rmhdr-logo{\n  font-family:'Montserrat',sans-serif;\n  font-weight:800;\n  font-size:18px;\n  color:#ffffff;\n  text-decoration:none;\n  letter-spacing:1px;\n  white-space:nowrap;\n  flex-shrink:0;\n}\n.rmhdr-logo b{color:#C9A84C;font-weight:800;}\n.rmhdr-right{\n  display:flex;\n  align-items:center;\n}\n.rmhdr-ul{\n  display:flex;\n  align-items:center;\n  gap:32px;\n  list-style:none;\n  margin:0;\n  padding:0;\n}\n.rmhdr-ul > li{\n  position:relative;\n}\n.rmhdr-ul > li > a{\n  font-family:'Montserrat',sans-serif;\n  font-weight:600;\n  font-size:13px;\n  letter-spacing:1px;\n  text-transform:uppercase;\n  color:rgba(255,255,255,0.8);\n  text-decoration:none;\n  transition:color 0.2s;\n  white-space:nowrap;\n  display:flex;\n  align-items:center;\n  gap:4px;\n  cursor:pointer;\n}\n.rmhdr-ul > li > a:hover,.rmhdr-ul > li > a.rmhdr-active{color:#C9A84C;}\n.rmhdr-dd{position:relative;}\n.rmhdr-sub{\n  position:absolute;\n  top:calc(100% + 16px);\n  left:0;\n  background:#0F1D35;\n  border:1px solid rgba(201,168,76,0.2);\n  border-top:2px solid #C9A84C;\n  min-width:220px;\n  opacity:0;\n  visibility:hidden;\n  transform:translateY(-6px);\n  transition:opacity 0.2s,transform 0.2s,visibility 0.2s;\n  padding:8px 0;\n  z-index:1001;\n}\n.rmhdr-dd:hover .rmhdr-sub{opacity:1;visibility:visible;transform:translateY(0);}\n.rmhdr-sub a{\n  display:block;\n  padding:10px 20px;\n  font-family:'Montserrat',sans-serif;\n  font-weight:600;\n  font-size:12px;\n  letter-spacing:1px;\n  text-transform:uppercase;\n  color:rgba(255,255,255,0.75);\n  text-decoration:none;\n  transition:color 0.2s;\n}\n.rmhdr-sub a em{\n  display:block;\n  font-family:'DM Sans',sans-serif;\n  font-weight:400;\n  font-size:11px;\n  letter-spacing:0;\n  text-transform:none;\n  font-style:normal;\n  color:rgba(255,255,255,0.45);\n  margin-top:2px;\n}\n.rmhdr-sub a:hover{color:#C9A84C;}\n.rmhdr-arrow{font-style:normal;font-size:8px;display:inline-block;transition:transform 0.2s;}\n.rmhdr-dd:hover .rmhdr-arrow{transform:rotate(180deg);}\n.rmhdr-cta{\n  display:inline-block;\n  background:#C0392B;\n  color:#ffffff;\n  font-family:'Montserrat',sans-serif;\n  font-weight:700;\n  font-size:12px;\n  letter-spacing:1.5px;\n  text-transform:uppercase;\n  text-decoration:none;\n  padding:12px 22px;\n  margin-left:32px;\n  flex-shrink:0;\n  transition:background 0.2s;\n  border-radius:2px;\n  white-space:nowrap;\n}\n.rmhdr-cta:hover{background:#a83225;color:#ffffff;}\n.rmhdr-burger{\n  display:none;\n  flex-direction:column;\n  gap:5px;\n  cursor:pointer;\n  padding:4px;\n  background:none;\n  border:none;\n  margin-left:16px;\n}\n.rmhdr-burger span{display:block;width:24px;height:2px;background:#ffffff;border-radius:1px;transition:all 0.3s;}\n@media(max-width:960px){\n  .rmhdr-ul{\n    display:none;\n    flex-direction:column;\n    position:absolute;\n    top:68px;left:0;right:0;\n    background:#0F1D35;\n    padding:20px 24px;\n    gap:14px;\n    border-bottom:2px solid rgba(201,168,76,0.25);\n    align-items:flex-start;\n    z-index:1000;\n  }\n  .rmhdr-ul.open{display:flex;}\n  .rmhdr-burger{display:flex;}\n  .rmhdr-sub{position:static;opacity:1;visibility:visible;transform:none;border:none;border-left:2px solid #C9A84C;background:transparent;padding:6px 0 0 12px;min-width:unset;display:none;}\n  .rmhdr-dd.open .rmhdr-sub{display:block;}\n  .rmhdr-cta{padding:9px 14px;font-size:10px;margin-left:8px;}\n}\n</style>\n\n<div class=\"rmhdr\">\n  <div class=\"rmhdr-in\">\n\n    <a href=\"/\" class=\"rmhdr-logo\">RIP <b>MEDIA</b></a>\n\n    <div class=\"rmhdr-right\">\n\n      <ul class=\"rmhdr-ul\" id=\"rmhdrUl\">\n\n        <li class=\"rmhdr-dd\">\n          <a href=\"/services/\">How We Work <i class=\"rmhdr-arrow\">&#9660;</i></a>\n          <div class=\"rmhdr-sub\">\n            <a href=\"/train/\">Train<em>I'll teach your team</em></a>\n            <a href=\"/consult/\">Consult<em>I'll guide your strategy</em></a>\n            <a href=\"/deliver/\">Deliver<em>My team builds it for you</em></a>\n          </div>\n        </li>\n\n        <li><a href=\"/portfolio/\">Our Work</a></li>\n        <li><a href=\"/results/\">Results</a></li>\n        <li><a href=\"/about/\">About</a></li>\n        <li><a href=\"/book/\">Book</a></li>\n\n      </ul>\n\n      <a href=\"/audit/\" class=\"rmhdr-cta\">Free Diagnosis</a>\n\n      <button class=\"rmhdr-burger\" id=\"rmhdrBurger\" aria-label=\"Menu\">\n        <span></span><span></span><span></span>\n      </button>\n\n    </div>\n  </div>\n</div>\n\n<script>\n(function(){\n  var b=document.getElementById('rmhdrBurger');\n  var u=document.getElementById('rmhdrUl');\n  var w=document.querySelector('.rmhdr');\n  if(b&&u){\n    b.addEventListener('click',function(e){\n      e.stopPropagation();\n      u.classList.toggle('open');\n    });\n    // Mobile: tap How We Work to expand dropdown\n    var dd=u.querySelector('.rmhdr-dd > a');\n    if(dd){\n      dd.addEventListener('click',function(e){\n        if(window.innerWidth<=960){\n          e.preventDefault();\n          dd.parentElement.classList.toggle('open');\n        }\n      });\n    }\n    document.addEventListener('click',function(e){\n      if(w&&!w.contains(e.target)){u.classList.remove('open');}\n    });\n  }\n  // Active link\n  var p=window.location.pathname;\n  document.querySelectorAll('.rmhdr-ul a').forEach(function(a){\n    try{var ap=new URL(a.href).pathname;if(ap!=='/'&&p.indexOf(ap)===0)a.classList.add('rmhdr-active');}catch(x){}\n  });\n})();\n</script>"}, "elements": []}]}]}]}