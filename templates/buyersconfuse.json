{"version": "0.4", "title": "buyersconfuse-v2", "type": "section", "content": [{"id": "bc_outer", "elType": "section", "isInner": false, "settings": {"background_background": "classic", "background_color": "#0A1628", "padding": {"unit": "px", "top": "80", "right": "40", "bottom": "80", "left": "40", "isLinked": false}, "content_width": {"unit": "px", "size": 1240}}, "elements": [{"id": "bc_col", "elType": "column", "settings": {"_column_size": 100}, "elements": [{"id": "bc_html", "elType": "widget", "widgetType": "html", "settings": {"html": "<style>\n.bc-wrap { font-family: 'DM Sans', sans-serif; color: #fff; }\n.bc-overline {\n  display: block;\n  font-family: 'Montserrat', sans-serif;\n  font-weight: 700;\n  font-size: 10px;\n  letter-spacing: 3px;\n  text-transform: uppercase;\n  color: #C9A84C;\n  margin-bottom: 16px;\n}\n.bc-heading {\n  font-family: 'Montserrat', sans-serif;\n  font-weight: 800;\n  font-size: clamp(28px, 3.2vw, 46px);\n  line-height: 1.15;\n  color: #fff;\n  letter-spacing: -0.5px;\n  margin-bottom: 16px;\n}\n.bc-sub {\n  color: rgba(255,255,255,0.62);\n  font-size: 16px;\n  max-width: 600px;\n  margin-bottom: 40px;\n  line-height: 1.6;\n}\n.bc-grid {\n  display: grid;\n  grid-template-columns: 1fr 1fr;\n  gap: 20px;\n  margin-bottom: 64px;\n}\n.bc-card {\n  background: #0F1D35;\n  border: 1px solid rgba(255,255,255,0.08);\n  border-radius: 16px;\n  padding: 28px 24px;\n  box-shadow: 0 10px 36px rgba(0,0,0,0.5);\n  transition: border-color 0.2s;\n}\n.bc-card:hover { border-color: rgba(201,168,76,0.3); }\n.bc-icon {\n  display: block;\n  font-size: 34px;\n  margin-bottom: 16px;\n  line-height: 1;\n}\n.bc-card h3 {\n  font-family: 'Montserrat', sans-serif;\n  font-weight: 700;\n  font-size: 17px;\n  line-height: 1.3;\n  color: #fff;\n  margin-bottom: 12px;\n}\n.bc-card p {\n  font-size: 14px;\n  color: rgba(255,255,255,0.58);\n  line-height: 1.65;\n}\n/* Heatmap section */\n.bc-hm-wrap {\n  background: rgba(255,255,255,0.03);\n  border: 1px solid rgba(255,255,255,0.08);\n  border-radius: 20px;\n  padding: 40px;\n  box-shadow: 0 8px 32px rgba(0,0,0,0.45);\n}\n.bc-hm-title {\n  font-family: 'Montserrat', sans-serif;\n  font-weight: 800;\n  font-size: clamp(22px, 2.8vw, 36px);\n  color: #fff;\n  line-height: 1.2;\n  margin-bottom: 12px;\n}\n.bc-hm-sub {\n  color: #C9A84C;\n  font-size: 14px;\n  font-weight: 600;\n  margin-bottom: 20px;\n}\n.bc-hm-table-wrap { overflow-x: auto; margin-bottom: 20px; }\n.bc-hm-table {\n  width: 100%;\n  border-collapse: collapse;\n  font-family: 'Montserrat', sans-serif;\n}\n.bc-hm-table thead th {\n  text-align: center;\n  padding: 10px 14px;\n  font-size: 10px;\n  letter-spacing: 1.5px;\n  text-transform: uppercase;\n  color: rgba(255,255,255,0.35);\n  border-bottom: 1px solid rgba(255,255,255,0.08);\n}\n.bc-hm-table thead th:first-child { text-align: left; }\n.bc-hm-table tbody tr td { border-bottom: 1px solid rgba(255,255,255,0.05); }\n.bc-row-label {\n  padding: 10px 14px;\n  font-family: 'Montserrat', sans-serif;\n  font-weight: 700;\n  font-size: 12px;\n  color: rgba(255,255,255,0.65);\n  white-space: nowrap;\n}\n.bc-cell { cursor: pointer; padding: 5px; }\n.bc-cell-inner {\n  border-radius: 7px;\n  padding: 10px 14px;\n  text-align: center;\n  font-family: 'Montserrat', sans-serif;\n  font-weight: 800;\n  font-size: 14px;\n  color: #fff;\n  transition: transform .15s, box-shadow .15s;\n}\n.bc-cell:hover .bc-cell-inner { transform: scale(1.08); box-shadow: 0 4px 18px rgba(0,0,0,0.5); }\n.bc-cell.bc-sel .bc-cell-inner { outline: 2px solid #C9A84C; outline-offset: 2px; }\n.bc-legend {\n  display: flex;\n  gap: 20px;\n  flex-wrap: wrap;\n  margin-bottom: 20px;\n}\n.bc-legend-item {\n  display: flex;\n  align-items: center;\n  gap: 8px;\n  font-size: 12px;\n  color: rgba(255,255,255,0.5);\n  font-family: 'DM Sans', sans-serif;\n}\n.bc-legend-swatch { width: 12px; height: 12px; border-radius: 3px; }\n.bc-detail {\n  display: none;\n  background: rgba(255,255,255,0.04);\n  border: 1px solid rgba(201,168,76,0.2);\n  border-radius: 12px;\n  padding: 20px;\n  margin-bottom: 20px;\n}\n.bc-detail.open { display: block; }\n.bc-stat-row { display: flex; gap: 24px; flex-wrap: wrap; margin-bottom: 16px; }\n.bc-stat-num {\n  font-family: 'Montserrat', sans-serif;\n  font-weight: 900;\n  font-size: 36px;\n  color: #C9A84C;\n  text-align: center;\n}\n.bc-stat-label {\n  font-size: 11px;\n  color: rgba(255,255,255,0.45);\n  text-transform: uppercase;\n  letter-spacing: 1px;\n  text-align: center;\n}\n.bc-detail-text {\n  font-size: 14px;\n  color: rgba(255,255,255,0.7);\n  line-height: 1.6;\n  margin-bottom: 12px;\n}\n.bc-rec {\n  background: rgba(201,168,76,0.1);\n  border-left: 3px solid #C9A84C;\n  padding: 12px 16px;\n  font-size: 13px;\n  color: rgba(255,255,255,0.8);\n  border-radius: 0 8px 8px 0;\n}\n.bc-custom-row { display: flex; gap: 12px; margin-top: 8px; }\n.bc-custom-input {\n  flex: 1;\n  background: rgba(255,255,255,0.06);\n  border: 1px solid rgba(255,255,255,0.12);\n  border-radius: 8px;\n  padding: 12px 16px;\n  color: #fff;\n  font-family: 'DM Sans', sans-serif;\n  font-size: 14px;\n  outline: none;\n}\n.bc-analyze-btn {\n  background: #C9A84C;\n  color: #0A1628;\n  border: none;\n  padding: 12px 24px;\n  border-radius: 8px;\n  font-family: 'Montserrat', sans-serif;\n  font-weight: 700;\n  font-size: 11px;\n  letter-spacing: 1.5px;\n  text-transform: uppercase;\n  cursor: pointer;\n  transition: background 0.2s;\n}\n.bc-analyze-btn:hover { background: #b8943a; }\n@media (max-width: 640px) {\n  .bc-grid { grid-template-columns: 1fr; }\n}\n</style>\n\n<div class=\"bc-wrap\">\n  <span class=\"bc-overline\">The Real Problem</span>\n  <h2 class=\"bc-heading\">When your buyers are confused, they say no.</h2>\n  <p class=\"bc-sub\">If these sound familiar, you need to fix it now.</p>\n\n  <div class=\"bc-grid\">\n    <div class=\"bc-card\">\n      <span class=\"bc-icon\">&#128263;</span>\n      <h3>Deals stall after the demo</h3>\n      <p>They were interested. Then they went quiet. It wasn't the product. It was the story that didn't stick.</p>\n    </div>\n    <div class=\"bc-card\">\n      <span class=\"bc-icon\">&#128184;</span>\n      <h3>Price becomes the conversation</h3>\n      <p>When buyers can't see a clear difference, they compare on the one thing they can quantify: cost.</p>\n    </div>\n    <div class=\"bc-card\">\n      <span class=\"bc-icon\">&#127919;</span>\n      <h3>Your team can't tell the same story twice</h3>\n      <p>Every rep explains it differently. Every deck says something slightly different. Buyers feel it.</p>\n    </div>\n    <div class=\"bc-card\">\n      <span class=\"bc-icon\">🤖</span>\n      <h3>AI and automation aren't moving the number</h3>\n      <p>You bought the tools. You built the sequences. The problem was never the machine. It was the message.</p>\n    </div>\n  </div>\n\n  <div class=\"bc-hm-wrap\">\n    <p class=\"bc-hm-title\">See How Confusion Hits Your Industry</p>\n    <p class=\"bc-hm-sub\">Click any cell for detailed insights. Or type your industry below.</p>\n    <div class=\"bc-hm-table-wrap\">\n      <table class=\"bc-hm-table\" id=\"bc-hm-table\">\n        <thead><tr>\n          <th></th>\n          <th>Story Overlap</th><th>Long Cycles</th><th>Price Pressure</th><th>Rep Inconsistency</th><th>Manual Outbound</th>\n        </tr></thead>\n        <tbody id=\"bc-hm-tbody\"></tbody>\n      </table>\n    </div>\n    <div class=\"bc-legend\">\n      <div class=\"bc-legend-item\"><div class=\"bc-legend-swatch\" style=\"background:rgba(34,197,94,0.7)\"></div>&lt;50 (Low)</div>\n      <div class=\"bc-legend-item\"><div class=\"bc-legend-swatch\" style=\"background:rgba(201,168,76,0.75)\"></div>50–70 (Moderate)</div>\n      <div class=\"bc-legend-item\"><div class=\"bc-legend-swatch\" style=\"background:rgba(201,100,30,0.82)\"></div>70–85 (High)</div>\n      <div class=\"bc-legend-item\"><div class=\"bc-legend-swatch\" style=\"background:rgba(192,57,43,0.88)\"></div>85+ (Critical)</div>\n    </div>\n    <div id=\"bc-hm-detail\" class=\"bc-detail\"></div>\n    <div class=\"bc-custom-row\">\n      <input type=\"text\" class=\"bc-custom-input\" id=\"bc-custom-input\" placeholder=\"Type your industry (e.g. Fintech, Healthcare IT)\">\n      <button class=\"bc-analyze-btn\" onclick=\"bcAnalyze()\">Analyze</button>\n    </div>\n  </div>\n</div>\n\n<script>\n(function(){\n  var D={\n    industries:['SaaS','Manufacturing','Medtech','Telecom','Prof. Services'],\n    pains:['Story Overlap','Long Cycles','Price Pressure','Rep Inconsistency','Manual Outbound'],\n    scores:[[88,72,65,81,77],[74,68,82,63,88],[71,85,74,69,72],[79,63,71,75,84],[85,57,68,88,65]],\n    details:{\n      '0-0':{stats:['88%','Story Overlap Rate'],text:'Most SaaS companies use nearly identical hero messages. Buyers see 4–6 pitches per week that sound the same.',rec:'Start with EPIC Framework: lead with the buyer problem, not the feature set.'},\n      '1-2':{stats:['82%','Price Sensitivity'],text:'Manufacturing buyers default to price comparisons when value is not clear.',rec:'A brand film showing outcomes reduces price objections by 40% on average.'},\n      '2-1':{stats:['85%','Cycle Length'],text:'Medtech sales cycles average 9–18 months. Every month without a differentiated story is a month where a competitor is building preference.',rec:'Story-first enablement reduces average cycle by 2.4 months.'},\n      '3-4':{stats:['84%','Manual Outbound'],text:'Telecom sales teams spend 60% of their time on manual outreach.',rec:'AI-automated outbound built on a clear story generates 3x response rates.'},\n      '4-3':{stats:['88%','Rep Inconsistency'],text:'Professional services firms have a major story consistency problem.',rec:'A unified EPIC story guide closes the consistency gap in 30 days or less.'}\n    }\n  };\n  function gc(s){return s<50?'rgba(34,197,94,0.7)':s<70?'rgba(201,168,76,0.75)':s<85?'rgba(201,100,30,0.82)':'rgba(192,57,43,0.88)';}\n  var sel=null;\n  function show(r,c,ind,pain,score,cell){\n    if(sel)sel.classList.remove('bc-sel');\n    sel=cell;cell.classList.add('bc-sel');\n    var key=r+'-'+c,d=D.details[key]||{stats:[score+'%','Severity Score'],text:ind+' companies face significant '+pain.toLowerCase()+' challenges.',rec:'A Story Differentiation Index audit will show exactly where the message is breaking.'};\n    var p=document.getElementById('bc-hm-detail');\n    p.className='bc-detail open';\n    p.innerHTML='<div class=\"bc-stat-row\"><div><div class=\"bc-stat-num\">'+d.stats[0]+'</div><div class=\"bc-stat-label\">'+d.stats[1]+'</div></div><div><div class=\"bc-stat-num\">'+ind+'</div><div class=\"bc-stat-label\">&times; '+pain+'</div></div></div><p class=\"bc-detail-text\">'+d.text+'</p><div class=\"bc-rec\">Recommended: '+d.rec+'</div>';\n  }\n  function build(){\n    var tb=document.getElementById('bc-hm-tbody');if(!tb)return;\n    D.industries.forEach(function(ind,r){\n      var tr=document.createElement('tr');\n      var td0=document.createElement('td');td0.className='bc-row-label';td0.textContent=ind;tr.appendChild(td0);\n      D.pains.forEach(function(pain,c){\n        var s=D.scores[r][c],td=document.createElement('td');\n        td.className='bc-cell';\n        td.innerHTML='<div class=\"bc-cell-inner\" style=\"background:'+gc(s)+'\">'+s+'</div>';\n        td.onclick=function(){show(r,c,ind,pain,s,td);};\n        tr.appendChild(td);\n      });\n      tb.appendChild(tr);\n    });\n  }\n  window.bcAnalyze=function(){\n    var val=document.getElementById('bc-custom-input').value.trim();if(!val)return;\n    var tb=document.getElementById('bc-hm-tbody'),ex=document.getElementById('bc-custom-row-el');if(ex)ex.remove();\n    var sc=D.pains.map(function(){return Math.floor(Math.random()*38+46);});\n    var tr=document.createElement('tr');tr.id='bc-custom-row-el';\n    var td0=document.createElement('td');td0.className='bc-row-label';td0.textContent=val+'*';tr.appendChild(td0);\n    sc.forEach(function(s,c){\n      var td=document.createElement('td');td.className='bc-cell';\n      td.innerHTML='<div class=\"bc-cell-inner\" style=\"background:'+gc(s)+'\">'+s+'</div>';\n      td.onclick=function(){show('c',c,val,D.pains[c],s,td);};\n      tr.appendChild(td);\n    });\n    tb.appendChild(tr);\n  };\n  build();\n})();\n</script>"}, "elements": []}]}]}], "page_settings": {}}