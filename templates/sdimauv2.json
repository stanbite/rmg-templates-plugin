{
  "version": "0.4",
  "title": "sdimauv2",
  "type": "section",
  "page_settings": {},
  "content": [
    {
      "id": "sdiv2_sec",
      "elType": "section",
      "isInner": false,
      "settings": {
        "background_background": "classic",
        "background_color": "#0A1628",
        "stretch_section": "section-stretched",
        "layout": "full_width",
        "gap": "no",
        "padding": { "unit": "px", "top": "40", "right": "20", "bottom": "40", "left": "20", "isLinked": false },
        "content_width": { "unit": "px", "size": 560 }
      },
      "elements": [
        {
          "id": "sdiv2_col",
          "elType": "column",
          "settings": { "_column_size": 100 },
          "elements": [
            {
              "id": "sdiv2_html",
              "elType": "widget",
              "widgetType": "html",
              "settings": {
                "html": "<link href=\"https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700;900&family=DM+Sans:wght@400;500&family=DM+Mono:wght@400;500&display=swap\" rel=\"stylesheet\">\n<style>\n.sdiv2*,.sdiv2*::before,.sdiv2*::after{box-sizing:border-box;margin:0;padding:0}\n.sdiv2{background:#0A1628;border-radius:16px;padding:28px 24px 22px;max-width:500px;width:100%;margin:0 auto}\n.sdiv2 .hero-title{font-family:'Montserrat',sans-serif;font-size:22px;font-weight:900;color:#ffffff;text-align:center;letter-spacing:1.5px;text-transform:uppercase;line-height:1.2;margin-bottom:5px}\n.sdiv2 .hero-sub{font-family:'DM Mono',monospace;font-size:10px;letter-spacing:3px;text-transform:uppercase;color:#C9A84C;text-align:center;margin-bottom:18px}\n.sdiv2 .gauge-area{position:relative;width:320px;margin:0 auto 6px}\n.sdiv2 .gauge-area canvas{display:block;width:100%}\n.sdiv2 .center-text{position:absolute;bottom:16px;left:50%;transform:translateX(-50%);text-align:center;pointer-events:none;white-space:nowrap}\n.sdiv2 .big-num{font-family:'Montserrat',sans-serif;font-size:44px;font-weight:900;color:#C9A84C;line-height:1;display:inline-block;min-width:70px}\n.sdiv2 .sub-label{font-family:'Montserrat',sans-serif;font-size:9px;letter-spacing:2px;text-transform:uppercase;color:#ffffff}\n.sdiv2 .band-stack{display:flex;flex-direction:column;gap:5px;margin-bottom:12px}\n.sdiv2 .band-row{display:grid;grid-template-columns:repeat(4,1fr);gap:5px}\n.sdiv2 .pip{border-radius:5px;padding:5px 6px;text-align:center;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.12);transition:all .3s}\n.sdiv2 .pip.active{border-color:rgba(201,168,76,.7);background:rgba(201,168,76,.1)}\n.sdiv2 .pip.unicorn-pip{border-color:rgba(34,197,94,.3);background:rgba(34,197,94,.05)}\n.sdiv2 .pip.unicorn-pip.active{border-color:rgba(34,197,94,.85);background:rgba(34,197,94,.14)}\n.sdiv2 .pip .pr{font-family:'DM Mono',monospace;font-size:10px;color:#ffffff;display:block}\n.sdiv2 .pip .pl{font-size:8px;font-weight:700;letter-spacing:.5px;text-transform:uppercase;color:#ffffff}\n.sdiv2 .pip.active .pl{color:#C9A84C}\n.sdiv2 .pip.unicorn-pip .pl,.sdiv2 .pip.unicorn-pip.active .pl{color:#22c55e}\n.sdiv2 .verdict{text-align:center;font-family:'Montserrat',sans-serif;font-size:12px;font-weight:700;color:rgba(255,255,255,0);min-height:18px;margin-bottom:12px;transition:color .5s;letter-spacing:.3px}\n.sdiv2 .verdict.on{color:#F7F7F2}\n.sdiv2 .sub-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:6px;margin-bottom:14px}\n.sdiv2 .sg{text-align:center}\n.sdiv2 .sg .sv{font-family:'DM Mono',monospace;font-size:13px;font-weight:500;color:#C9A84C}\n.sdiv2 .sg .sn{font-family:'Montserrat',sans-serif;font-size:8px;letter-spacing:.4px;text-transform:uppercase;color:#ffffff;margin-top:2px}\n.sdiv2 .seg-bar{height:3px;border-radius:2px;background:rgba(255,255,255,.12);margin:3px 2px 0;overflow:hidden}\n.sdiv2 .seg-fill{height:100%;border-radius:2px;width:0;transition:width 1.4s cubic-bezier(.22,1,.36,1)}\n.sdiv2 .input-row{display:flex;gap:8px}\n.sdiv2 .sdi-input{flex:1;padding:10px 12px;border-radius:8px;font-size:13px;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.3);color:#F7F7F2;outline:none;font-family:'DM Sans',sans-serif}\n.sdiv2 .sdi-input:focus{border-color:#C9A84C}\n.sdiv2 .sdi-input::placeholder{color:rgba(255,255,255,.5)}\n.sdiv2 .sdi-btn{padding:10px 20px;border-radius:8px;font-family:'Montserrat',sans-serif;font-weight:700;font-size:11px;letter-spacing:1px;text-transform:uppercase;border:none;cursor:pointer;background:#C9A84C;color:#0A1628;white-space:nowrap}\n.sdiv2 .sdi-btn:hover{opacity:.85}\n.sdiv2 .lead-panel{display:none;margin-top:16px;border-radius:12px;border:1px solid rgba(201,168,76,.35);background:linear-gradient(135deg,rgba(201,168,76,.08),rgba(27,58,138,.12));padding:20px 18px}\n.sdiv2 .lead-panel.show{display:block;animation:sdiv2In .4s cubic-bezier(.22,1,.36,1)}\n@keyframes sdiv2In{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}\n.sdiv2 .lead-eyebrow{font-family:'DM Mono',monospace;font-size:9px;letter-spacing:3px;text-transform:uppercase;color:#C9A84C;margin-bottom:6px}\n.sdiv2 .lead-headline{font-family:'Montserrat',sans-serif;font-size:15px;font-weight:900;color:#ffffff;line-height:1.3;margin-bottom:6px}\n.sdiv2 .lead-headline span{color:#C9A84C}\n.sdiv2 .lead-body{font-family:'DM Sans',sans-serif;font-size:12px;color:rgba(255,255,255,.8);line-height:1.6;margin-bottom:14px}\n.sdiv2 .lead-bullets{list-style:none;margin-bottom:16px;display:flex;flex-direction:column;gap:6px}\n.sdiv2 .lead-bullets li{font-family:'DM Sans',sans-serif;font-size:12px;color:#ffffff;display:flex;align-items:flex-start;gap:8px}\n.sdiv2 .lead-bullets li::before{content:'';display:block;width:6px;height:6px;border-radius:50%;background:#22c55e;margin-top:5px;flex-shrink:0}\n.sdiv2 .lead-form{display:flex;gap:8px}\n.sdiv2 .lead-email{flex:1;padding:11px 14px;border-radius:8px;font-size:13px;font-family:'DM Sans',sans-serif;background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.3);color:#F7F7F2;outline:none}\n.sdiv2 .lead-email:focus{border-color:#C9A84C}\n.sdiv2 .lead-email::placeholder{color:rgba(255,255,255,.4)}\n.sdiv2 .lead-submit{padding:11px 20px;border-radius:8px;font-family:'Montserrat',sans-serif;font-weight:900;font-size:11px;letter-spacing:1px;text-transform:uppercase;border:none;cursor:pointer;background:#C0392B;color:#ffffff;white-space:nowrap;transition:opacity .2s}\n.sdiv2 .lead-submit:hover{opacity:.88}\n.sdiv2 .lead-fine{font-family:'DM Sans',sans-serif;font-size:10px;color:rgba(255,255,255,.3);text-align:center;margin-top:8px}\n.sdiv2 .confirm-panel{display:none;margin-top:16px;border-radius:12px;border:1px solid rgba(34,197,94,.4);background:rgba(34,197,94,.07);padding:20px 18px;text-align:center}\n.sdiv2 .confirm-panel.show{display:block;animation:sdiv2In .4s cubic-bezier(.22,1,.36,1)}\n.sdiv2 .confirm-icon{font-size:28px;margin-bottom:8px}\n.sdiv2 .confirm-head{font-family:'Montserrat',sans-serif;font-size:15px;font-weight:900;color:#22c55e;margin-bottom:6px}\n.sdiv2 .confirm-body{font-family:'DM Sans',sans-serif;font-size:12px;color:rgba(255,255,255,.8);line-height:1.6}\n</style>\n\n<div class=\"sdiv2\">\n  <div class=\"hero-title\">Measure Your Sales Story Here</div>\n  <div class=\"hero-sub\">Sales Differentiator Index</div>\n\n  <div class=\"gauge-area\">\n    <canvas id=\"sdiv2_cv\" width=\"320\" height=\"190\"></canvas>\n    <div class=\"center-text\">\n      <div class=\"big-num\" id=\"sdiv2_num\">&mdash;</div>\n      <div class=\"sub-label\">SDI Score</div>\n    </div>\n  </div>\n\n  <div class=\"band-stack\">\n    <div class=\"band-row\">\n      <div class=\"pip\" id=\"sdiv2_p0\"><span class=\"pr\">0-24</span><span class=\"pl\">Invisible</span></div>\n      <div class=\"pip\" id=\"sdiv2_p1\"><span class=\"pr\">25-44</span><span class=\"pl\">Critical</span></div>\n      <div class=\"pip\" id=\"sdiv2_p2\"><span class=\"pr\">45-64</span><span class=\"pl\">Overlap</span></div>\n      <div class=\"pip\" id=\"sdiv2_p3\"><span class=\"pr\">65-84</span><span class=\"pl\">Partial</span></div>\n    </div>\n    <div>\n      <div class=\"pip unicorn-pip\" id=\"sdiv2_p4\"><span class=\"pr\">85-100</span><span class=\"pl\">&#11088; Unicorn &mdash; Genuinely Differentiated</span></div>\n    </div>\n  </div>\n\n  <div class=\"verdict\" id=\"sdiv2_verd\">Enter your URL. Find out where you really stand.</div>\n\n  <div class=\"sub-grid\">\n    <div class=\"sg\"><div class=\"sv\" id=\"sdiv2_sc0\">--</div><div class=\"seg-bar\"><div class=\"seg-fill\" id=\"sdiv2_sf0\"></div></div><div class=\"sn\">Language</div></div>\n    <div class=\"sg\"><div class=\"sv\" id=\"sdiv2_sc1\">--</div><div class=\"seg-bar\"><div class=\"seg-fill\" id=\"sdiv2_sf1\"></div></div><div class=\"sn\">Specificity</div></div>\n    <div class=\"sg\"><div class=\"sv\" id=\"sdiv2_sc2\">--</div><div class=\"seg-bar\"><div class=\"seg-fill\" id=\"sdiv2_sf2\"></div></div><div class=\"sn\">Problem</div></div>\n    <div class=\"sg\"><div class=\"sv\" id=\"sdiv2_sc3\">--</div><div class=\"seg-bar\"><div class=\"seg-fill\" id=\"sdiv2_sf3\"></div></div><div class=\"sn\">Unicorn</div></div>\n    <div class=\"sg\"><div class=\"sv\" id=\"sdiv2_sc4\">--</div><div class=\"seg-bar\"><div class=\"seg-fill\" id=\"sdiv2_sf4\"></div></div><div class=\"sn\">Consistency</div></div>\n  </div>\n\n  <div class=\"input-row\">\n    <input type=\"text\" id=\"sdiv2_url\" class=\"sdi-input\" placeholder=\"yourcompany.com\">\n    <button id=\"sdiv2_btn\" class=\"sdi-btn\">Score It</button>\n  </div>\n\n  <div class=\"lead-panel\" id=\"sdiv2_lead\">\n    <div class=\"lead-eyebrow\">Your Free Deep Dive Awaits</div>\n    <div class=\"lead-headline\">Your score is just the start.<br><span id=\"sdiv2_leadline\"></span></div>\n    <div class=\"lead-body\">Get the full picture &mdash; free. We&rsquo;ll send you exactly what&rsquo;s pulling your score down, plus how your top 3 competitors score against you.</div>\n    <ul class=\"lead-bullets\">\n      <li>Your full SDI breakdown across all 5 dimensions</li>\n      <li>Named competitor scores &mdash; see exactly who&rsquo;s beating you and why</li>\n      <li>The 3 specific fixes that move your score the fastest</li>\n    </ul>\n    <div class=\"lead-form\">\n      <input type=\"email\" id=\"sdiv2_email\" class=\"lead-email\" placeholder=\"your@email.com\">\n      <button id=\"sdiv2_submit\" class=\"lead-submit\">Get It Free</button>\n    </div>\n    <div class=\"lead-fine\">No spam. One email. Unsubscribe anytime.</div>\n  </div>\n\n  <div class=\"confirm-panel\" id=\"sdiv2_confirm\">\n    <div class=\"confirm-icon\">&#10003;</div>\n    <div class=\"confirm-head\">Analysis on its way.</div>\n    <div class=\"confirm-body\">Check your inbox. Your full SDI breakdown &mdash; including competitor scores and the fixes that matter &mdash; will be there within minutes.</div>\n  </div>\n</div>\n\n<script>\n(function(){\n  var cv=document.getElementById('sdiv2_cv');\n  if(!cv)return;\n  var ctx=cv.getContext('2d');\n  var CX=160,CY=168,R=118;\n  var DEG=Math.PI/180;\n  var startA=200*DEG,endA=340*DEG,sweep=endA-startA;\n  var segColors=['#C0392B','#E8700A','#D4B800','#C9A84C','#22c55e'];\n  var verdicts=[\n    \"Invisible. Buyers can't tell you apart.\",\n    \"Critical overlap. Being commoditized.\",\n    \"High overlap. Buyers default to price.\",\n    \"Partially differentiated. Seed of a story.\",\n    \"Unicorn. Genuinely differentiated.\"\n  ];\n  var leadLines=[\n    \"Most B2B companies score here. Your buyers are confused.\",\n    \"You're losing deals to companies with worse products.\",\n    \"Buyers can't tell you apart. That's fixable.\",\n    \"You're close. A few fixes and you break through.\",\n    \"You're rare. Let's make sure it stays that way.\"\n  ];\n  function band(s){return s<25?0:s<45?1:s<65?2:s<85?3:4;}\n  function col(s){return segColors[band(s)];}\n  function draw(na){\n    ctx.clearRect(0,0,320,190);\n    for(var i=0;i<5;i++){\n      var a0=startA+sweep*(i/5),a1=startA+sweep*((i+1)/5);\n      ctx.strokeStyle=segColors[i];ctx.lineWidth=18;ctx.lineCap='butt';\n      ctx.beginPath();ctx.arc(CX,CY,R,a0,a1);ctx.stroke();\n    }\n    ctx.strokeStyle='#0A1628';ctx.lineWidth=2.5;\n    for(var i=1;i<5;i++){\n      var a=startA+sweep*(i/5);\n      ctx.beginPath();\n      ctx.moveTo(CX+(R-9)*Math.cos(a),CY+(R-9)*Math.sin(a));\n      ctx.lineTo(CX+(R+9)*Math.cos(a),CY+(R+9)*Math.sin(a));\n      ctx.stroke();\n    }\n    ctx.strokeStyle='rgba(255,255,255,0.28)';ctx.lineWidth=1;\n    for(var i=0;i<=20;i++){\n      var a=startA+sweep*(i/20);\n      ctx.beginPath();\n      ctx.moveTo(CX+(R+10)*Math.cos(a),CY+(R+10)*Math.sin(a));\n      ctx.lineTo(CX+(R+17)*Math.cos(a),CY+(R+17)*Math.sin(a));\n      ctx.stroke();\n    }\n    ctx.save();\n    ctx.shadowColor='rgba(255,255,255,0.4)';ctx.shadowBlur=8;\n    ctx.strokeStyle='#ffffff';ctx.lineWidth=3;ctx.lineCap='round';\n    ctx.beginPath();ctx.moveTo(CX,CY);\n    ctx.lineTo(CX+(R-14)*Math.cos(na),CY+(R-14)*Math.sin(na));\n    ctx.stroke();ctx.restore();\n    ctx.fillStyle='#F7F7F2';ctx.beginPath();ctx.arc(CX,CY,9,0,Math.PI*2);ctx.fill();\n    ctx.fillStyle='#0A1628';ctx.beginPath();ctx.arc(CX,CY,5,0,Math.PI*2);ctx.fill();\n  }\n  var idleMin=startA+sweep*(0.5/5),idleMax=startA+sweep*(2.5/5);\n  var needle=idleMin,target=idleMin,cur=0,tsc=0,idle=true,it=0,id=1;\n  function loop(){\n    if(idle){\n      it+=0.006*id;\n      if(it>=1){it=1;id=-1;}if(it<=0){it=0;id=1;}\n      needle=idleMin+(idleMax-idleMin)*(1-Math.cos(it*Math.PI))/2;\n    }else{\n      needle+=(target-needle)*0.05;\n      cur+=(tsc-cur)*0.05;\n    }\n    draw(needle);\n    var el=document.getElementById('sdiv2_num');\n    if(el)el.textContent=(!idle&&cur>1)?Math.round(cur):'--';\n    requestAnimationFrame(loop);\n  }\n  function run(){\n    var url=document.getElementById('sdiv2_url').value.trim();if(!url)return;\n    idle=false;\n    tsc=Math.floor(Math.random()*60)+20;\n    target=startA+sweep*(tsc/100);\n    var b=band(tsc),fc=col(tsc);\n    var verd=document.getElementById('sdiv2_verd');\n    if(verd){verd.textContent=verdicts[b];verd.classList.add('on');}\n    for(var i=0;i<5;i++){\n      var pip=document.getElementById('sdiv2_p'+i);\n      var sf=document.getElementById('sdiv2_sf'+i);\n      if(pip)pip.classList.toggle('active',i===b);\n      if(sf)sf.style.background=fc;\n      (function(x){\n        setTimeout(function(){\n          var v=Math.floor(Math.random()*50)+30;\n          var sc=document.getElementById('sdiv2_sc'+x);\n          var fill=document.getElementById('sdiv2_sf'+x);\n          if(sc)sc.textContent=v;\n          if(fill)fill.style.width=v+'%';\n        },150+x*80);\n      })(i);\n    }\n    setTimeout(function(){\n      var ll=document.getElementById('sdiv2_leadline');\n      var lp=document.getElementById('sdiv2_lead');\n      if(ll)ll.textContent=leadLines[band(Math.round(tsc))];\n      if(lp)lp.classList.add('show');\n    },2200);\n  }\n  var btn=document.getElementById('sdiv2_btn');\n  var urlEl=document.getElementById('sdiv2_url');\n  var submitBtn=document.getElementById('sdiv2_submit');\n  var emailEl=document.getElementById('sdiv2_email');\n  if(btn)btn.addEventListener('click',run);\n  if(urlEl)urlEl.addEventListener('keydown',function(e){if(e.key==='Enter')run();});\n  if(submitBtn)submitBtn.addEventListener('click',function(){\n    var em=emailEl?emailEl.value.trim():'';\n    if(!em||!em.includes('@'))return;\n    var lp=document.getElementById('sdiv2_lead');\n    var cp=document.getElementById('sdiv2_confirm');\n    if(lp){lp.classList.remove('show');lp.style.display='none';}\n    if(cp)cp.classList.add('show');\n  });\n  if(emailEl)emailEl.addEventListener('keydown',function(e){\n    if(e.key==='Enter'&&submitBtn)submitBtn.click();\n  });\n  loop();\n})();\n</script>"
              },
              "elements": []
            }
          ]
        }
      ]
    }
  ]
}
