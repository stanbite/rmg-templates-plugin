              "widgetType": "html",
              "settings": {
                "html": "<link href=\"https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;900&family=DM+Sans:wght@400;500;600&family=DM+Mono:wght@400;500&display=swap\" rel=\"stylesheet\">\n<style>\n*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }\n:root {\n  --navy: #0A1628; --gold: #C9A84C; --red: #C0392B;\n  --offwhite: #F7F7F2; --royal: #1B3A8A; --white: #ffffff;\n}\nbody { background: var(--offwhite); font-family: 'DM Sans', sans-serif; color: var(--navy); overflow-x: hidden; }\n.banner { background: var(--navy); padding: 18px 40px; display: flex; align-items: center; justify-content: space-between; }\n.banner-logo { font-family: 'Montserrat', sans-serif; font-weight: 900; font-size: 15px; letter-spacing: 2px; text-transform: uppercase; color: var(--white); }\n.banner-logo span { color: var(--gold); }\n.banner-tagline { font-family: 'DM Mono', monospace; font-size: 10px; letter-spacing: 2px; text-transform: uppercase; color: rgba(255,255,255,0.5); }\n.hero { background: linear-gradient(160deg, #0A1628 0%, #0f2347 35%, #1B3A8A 75%, #0e2255 100%); padding: 70px 40px 80px; text-align: center; position: relative; overflow: hidden; }\n.hero::before { content: ''; position: absolute; top: -40px; left: 50%; transform: translateX(-50%); width: 700px; height: 500px; background: radial-gradient(ellipse, rgba(27,58,138,0.25) 0%, transparent 65%); pointer-events: none; z-index: 0; }\n.hero-waves { position: absolute; inset: 0; width: 100%; height: 100%; pointer-events: none; z-index: 0; }\n.hero > *:not(.hero-waves) { position: relative; z-index: 1; }\n.hero h1 { font-family: 'Montserrat', sans-serif; font-weight: 900; font-size: clamp(32px, 5vw, 56px); line-height: 1.05; color: var(--white); max-width: 780px; margin: 0 auto 16px; }\n.hero h1 em { color: var(--gold); font-style: normal; }\n.hero-sub { font-size: 17px; color: rgba(255,255,255,0.65); max-width: 560px; margin: 0 auto 36px; line-height: 1.6; }\n.hero-cta { display: inline-block; background: var(--red); color: var(--white); font-family: 'Montserrat', sans-serif; font-weight: 700; font-size: 12px; letter-spacing: 1.5px; text-transform: uppercase; padding: 16px 36px; border-radius: 4px; text-decoration: none; transition: opacity 0.2s; }\n.hero-cta:hover { opacity: 0.85; }\n.section { padding: 70px 40px; max-width: 960px; margin: 0 auto; }\n.section-label { font-family: 'DM Mono', monospace; font-size: 10px; letter-spacing: 3px; text-transform: uppercase; color: var(--gold); margin-bottom: 12px; }\n.section h2 { font-family: 'Montserrat', sans-serif; font-weight: 900; font-size: clamp(24px, 3.5vw, 38px); line-height: 1.15; color: var(--navy); margin-bottom: 20px; }\n.section p { font-size: 16px; line-height: 1.7; color: #3a4a60; max-width: 680px; }\n.stat-bar { background: var(--navy); padding: 40px; }\n.stat-bar-inner { max-width: 960px; margin: 0 auto; display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; text-align: center; }\n.stat-num { font-family: 'Montserrat', sans-serif; font-weight: 900; font-size: 36px; color: var(--gold); line-height: 1; margin-bottom: 6px; }\n.stat-desc { font-size: 12px; color: rgba(255,255,255,0.6); letter-spacing: 0.5px; line-height: 1.4; }\n.confusion-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-top: 40px; }\n.confusion-card { background: var(--white); border: 1px solid rgba(10,22,40,0.08); border-radius: 8px; padding: 28px; position: relative; overflow: hidden; transition: transform 0.2s, box-shadow 0.2s; }\n.confusion-card:hover { transform: translateY(-3px); box-shadow: 0 12px 40px rgba(10,22,40,0.1); }\n.confusion-card::before { content: ''; position: absolute; top: 0; left: 0; width: 3px; height: 100%; background: var(--gold); }\n.card-num { font-family: 'Montserrat', sans-serif; font-weight: 900; font-size: 48px; color: rgba(10,22,40,0.06); position: absolute; top: 10px; right: 16px; line-height: 1; }\n.card-title { font-family: 'Montserrat', sans-serif; font-weight: 700; font-size: 14px; color: var(--navy); margin-bottom: 8px; text-transform: uppercase; letter-spacing: 0.5px; }\n.card-body { font-size: 14px; color: #5a6a80; line-height: 1.6; }\n.calc-section { background: var(--navy); padding: 70px 40px; }\n.calc-inner { max-width: 820px; margin: 0 auto; }\n.calc-label { font-family: 'DM Mono', monospace; font-size: 10px; letter-spacing: 3px; text-transform: uppercase; color: var(--gold); margin-bottom: 12px; }\n.calc-inner h2 { font-family: 'Montserrat', sans-serif; font-weight: 900; font-size: clamp(24px, 3.5vw, 36px); color: var(--white); margin-bottom: 10px; }\n.calc-sub { font-size: 15px; color: rgba(255,255,255,0.55); margin-bottom: 40px; line-height: 1.6; }\n.calc-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 20px; margin-bottom: 30px; }\n.calc-field label { display: block; font-family: 'DM Mono', monospace; font-size: 10px; letter-spacing: 2px; text-transform: uppercase; color: var(--gold); margin-bottom: 10px; }\n.calc-field input { width: 100%; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.2); border-radius: 6px; padding: 14px 16px; font-family: 'Montserrat', sans-serif; font-weight: 700; font-size: 22px; color: var(--white); outline: none; transition: border-color 0.2s; -moz-appearance: textfield; }\n.calc-field input::-webkit-outer-spin-button, .calc-field input::-webkit-inner-spin-button { -webkit-appearance: none; }\n.calc-field input:focus { border-color: var(--gold); }\n.calc-results { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 16px; margin-top: 10px; }\n.result-box { background: rgba(255,255,255,0.05); border: 1px solid rgba(201,168,76,0.25); border-radius: 8px; padding: 24px 20px; text-align: center; }\n.result-box.highlight { background: rgba(201,168,76,0.1); border-color: var(--gold); }\n.result-label { font-family: 'DM Mono', monospace; font-size: 9px; letter-spacing: 2px; text-transform: uppercase; color: rgba(255,255,255,0.5); margin-bottom: 10px; }\n.result-num { font-family: 'Montserrat', sans-serif; font-weight: 900; font-size: 30px; color: var(--gold); line-height: 1; margin-bottom: 6px; }\n.result-sub { font-size: 11px; color: rgba(255,255,255,0.4); line-height: 1.4; }\n.calc-note { margin-top: 20px; font-size: 12px; color: rgba(255,255,255,0.35); line-height: 1.6; font-style: italic; }\n.sdi-section { background: var(--offwhite); padding: 70px 40px; }\n.sdi-inner { max-width: 820px; margin: 0 auto; }\n.sdi-inner h2 { font-family: 'Montserrat', sans-serif; font-weight: 900; font-size: clamp(24px,3.5vw,36px); color: var(--navy); margin-bottom: 10px; }\n.sdi-desc { font-size: 15px; color: #5a6a80; margin-bottom: 36px; line-height: 1.6; max-width: 600px; }\n.sdi-questions { display: flex; flex-direction: column; gap: 16px; margin-bottom: 30px; }\n.sdi-q { background: var(--white); border: 1px solid rgba(10,22,40,0.08); border-radius: 8px; padding: 20px 24px; }\n.sdi-q-text { font-size: 14px; font-weight: 600; color: var(--navy); margin-bottom: 14px; line-height: 1.5; }\n.sdi-options { display: flex; gap: 10px; flex-wrap: wrap; }\n.sdi-opt { padding: 8px 16px; border-radius: 4px; border: 1.5px solid rgba(10,22,40,0.15); background: transparent; font-family: 'DM Sans', sans-serif; font-size: 13px; color: var(--navy); cursor: pointer; transition: all 0.2s; }\n.sdi-opt:hover { border-color: var(--gold); background: rgba(201,168,76,0.08); }\n.sdi-opt.selected { border-color: var(--navy); background: var(--navy); color: var(--white); }\n.sdi-run-btn { display: block; width: 100%; padding: 18px; background: var(--red); color: var(--white); font-family: 'Montserrat', sans-serif; font-weight: 700; font-size: 13px; letter-spacing: 1.5px; text-transform: uppercase; border: none; border-radius: 6px; cursor: pointer; transition: opacity 0.2s; margin-bottom: 20px; }\n.sdi-run-btn:hover { opacity: 0.85; }\n.sdi-result-panel { display: none; background: var(--navy); border-radius: 10px; padding: 36px; text-align: center; }\n.sdi-result-panel.visible { display: block; }\n.sdi-score-display { font-family: 'Montserrat', sans-serif; font-weight: 900; font-size: 80px; color: var(--gold); line-height: 1; margin-bottom: 8px; }\n.sdi-score-label { font-family: 'DM Mono', monospace; font-size: 11px; letter-spacing: 3px; text-transform: uppercase; color: rgba(255,255,255,0.5); margin-bottom: 20px; }\n.sdi-verdict { font-family: 'Montserrat', sans-serif; font-weight: 700; font-size: 18px; color: var(--white); margin-bottom: 14px; }\n.sdi-caveat { font-size: 13px; color: rgba(255,255,255,0.5); line-height: 1.7; max-width: 480px; margin: 0 auto 24px; padding: 16px; border: 1px solid rgba(201,168,76,0.25); border-radius: 6px; background: rgba(201,168,76,0.05); }\n.sdi-caveat strong { color: var(--gold); }\n.sdi-deep-btn { display: inline-block; background: var(--red); color: var(--white); font-family: 'Montserrat', sans-serif; font-weight: 700; font-size: 12px; letter-spacing: 1.5px; text-transform: uppercase; padding: 14px 32px; border-radius: 4px; text-decoration: none; transition: opacity 0.2s; }\n.sdi-deep-btn:hover { opacity: 0.85; }\n.proof-section { background: var(--white); padding: 70px 40px; }\n.proof-inner { max-width: 960px; margin: 0 auto; }\n.proof-inner .section-label { color: var(--gold); }\n.proof-inner h2 { font-family: 'Montserrat', sans-serif; font-weight: 900; font-size: clamp(24px,3.5vw,36px); color: var(--navy); margin-bottom: 40px; }\n.proof-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }\n.proof-card { border: 1px solid rgba(10,22,40,0.08); border-radius: 8px; padding: 28px; position: relative; overflow: hidden; transition: transform 0.2s, box-shadow 0.2s; }\n.proof-card:hover { transform: translateY(-3px); box-shadow: 0 12px 40px rgba(10,22,40,0.08); }\n.proof-card::after { content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 3px; background: var(--gold); }\n.proof-company { font-family: 'Montserrat', sans-serif; font-weight: 700; font-size: 11px; letter-spacing: 2px; text-transform: uppercase; color: rgba(10,22,40,0.4); margin-bottom: 12px; }\n.proof-result { font-family: 'Montserrat', sans-serif; font-weight: 900; font-size: 30px; color: var(--navy); line-height: 1.1; margin-bottom: 10px; }\n.proof-result span { color: var(--red); }\n.proof-desc { font-size: 13px; color: #7a8a9a; line-height: 1.6; }\n.teaser-section { background: var(--navy); padding: 70px 40px; text-align: center; position: relative; overflow: hidden; }\n.teaser-section::before { content: ''; position: absolute; bottom: -80px; left: 50%; transform: translateX(-50%); width: 500px; height: 500px; background: radial-gradient(circle, rgba(192,57,43,0.12) 0%, transparent 70%); pointer-events: none; }\n.teaser-inner { max-width: 660px; margin: 0 auto; position: relative; }\n.teaser-eyebrow { font-family: 'DM Mono', monospace; font-size: 10px; letter-spacing: 3px; text-transform: uppercase; color: var(--gold); margin-bottom: 20px; }\n.teaser-inner h2 { font-family: 'Montserrat', sans-serif; font-weight: 900; font-size: clamp(26px,4vw,40px); color: var(--white); line-height: 1.15; margin-bottom: 20px; }\n.teaser-inner h2 em { color: var(--gold); font-style: normal; }\n.teaser-body { font-size: 16px; color: rgba(255,255,255,0.6); line-height: 1.7; margin-bottom: 36px; }\n.teaser-cta { display: inline-block; background: var(--red); color: var(--white); font-family: 'Montserrat', sans-serif; font-weight: 700; font-size: 12px; letter-spacing: 1.5px; text-transform: uppercase; padding: 16px 36px; border-radius: 4px; text-decoration: none; transition: opacity 0.2s; }\n.teaser-cta:hover { opacity: 0.85; }\n.teaser-timer { margin-top: 20px; font-family: 'DM Mono', monospace; font-size: 11px; letter-spacing: 2px; color: rgba(255,255,255,0.3); }\n.footer { background: #060e1a; padding: 30px 40px; display: flex; align-items: center; justify-content: space-between; }\n.footer-logo { font-family: 'Montserrat', sans-serif; font-weight: 900; font-size: 13px; letter-spacing: 2px; text-transform: uppercase; color: rgba(255,255,255,0.4); }\n.footer-logo span { color: var(--gold); }\n.footer-link { font-family: 'DM Mono', monospace; font-size: 10px; letter-spacing: 2px; text-transform: uppercase; color: rgba(255,255,255,0.3); text-decoration: none; }\n.footer-link:hover { color: var(--gold); }\n.fade-in { opacity: 0; transform: translateY(20px); transition: opacity 0.6s ease, transform 0.6s ease; }\n.fade-in.visible { opacity: 1; transform: translateY(0); }\n@media (max-width: 700px) {\n  .banner { flex-direction: column; gap: 8px; text-align: center; }\n  .stat-bar-inner { grid-template-columns: repeat(2, 1fr); }\n  .confusion-grid { grid-template-columns: 1fr; }\n  .calc-grid { grid-template-columns: 1fr; }\n  .calc-results { grid-template-columns: 1fr; }\n  .proof-grid { grid-template-columns: 1fr; }\n  .footer { flex-direction: column; gap: 12px; text-align: center; }\n}\n</style>\n<div class=\"banner\">\n  <div class=\"banner-logo\">Rip Media <span>Group</span></div>\n  <div class=\"banner-tagline\">Story &middot; Assets &middot; Machine</div>\n</div>\n\n<div class=\"hero\">\n  <svg class=\"hero-waves\" viewBox=\"0 0 1440 500\" preserveAspectRatio=\"xMidYMid slice\" xmlns=\"http://www.w3.org/2000/svg\">\n    <defs>\n      <style>\n        .w1 { animation: waveShift1 12s ease-in-out infinite alternate; }\n        .w2 { animation: waveShift2 16s ease-in-out infinite alternate; }\n        .w3 { animation: waveShift3 20s ease-in-out infinite alternate; }\n        @keyframes waveShift1 {\n          0%   { d: path(\"M0,280 C200,240 400,320 600,280 C800,240 1000,300 1200,260 C1350,230 1400,250 1440,240 L1440,500 L0,500 Z\"); }\n          100% { d: path(\"M0,300 C180,260 380,340 580,300 C780,260 980,320 1180,270 C1340,240 1400,260 1440,255 L1440,500 L0,500 Z\"); }\n        }\n        @keyframes waveShift2 {\n          0%   { d: path(\"M0,340 C220,300 440,380 660,340 C880,300 1060,360 1260,320 C1380,295 1420,310 1440,305 L1440,500 L0,500 Z\"); }\n          100% { d: path(\"M0,320 C240,280 460,360 680,320 C900,280 1080,340 1280,305 C1390,282 1425,295 1440,290 L1440,500 L0,500 Z\"); }\n        }\n        @keyframes waveShift3 {\n          0%   { d: path(\"M0,390 C260,355 480,420 720,390 C960,355 1120,405 1340,375 C1400,362 1430,370 1440,368 L1440,500 L0,500 Z\"); }\n          100% { d: path(\"M0,375 C270,340 500,405 740,375 C980,340 1140,390 1360,362 C1410,350 1435,358 1440,355 L1440,500 L0,500 Z\"); }\n        }\n      </style>\n      <linearGradient id=\"wg1\" x1=\"0%\" y1=\"0%\" x2=\"100%\" y2=\"0%\">\n        <stop offset=\"0%\" stop-color=\"#0A1628\" stop-opacity=\"0.30\"/>\n        <stop offset=\"50%\" stop-color=\"#1B3A8A\" stop-opacity=\"0.18\"/>\n        <stop offset=\"100%\" stop-color=\"#0A1628\" stop-opacity=\"0.25\"/>\n      </linearGradient>\n      <linearGradient id=\"wg2\" x1=\"0%\" y1=\"0%\" x2=\"100%\" y2=\"0%\">\n        <stop offset=\"0%\" stop-color=\"#1B3A8A\" stop-opacity=\"0.22\"/>\n        <stop offset=\"50%\" stop-color=\"#0A1628\" stop-opacity=\"0.12\"/>\n        <stop offset=\"100%\" stop-color=\"#1B3A8A\" stop-opacity=\"0.20\"/>\n      </linearGradient>\n      <linearGradient id=\"wg3\" x1=\"0%\" y1=\"0%\" x2=\"100%\" y2=\"0%\">\n        <stop offset=\"0%\" stop-color=\"#0A1628\" stop-opacity=\"0.35\"/>\n        <stop offset=\"100%\" stop-color=\"#1B3A8A\" stop-opacity=\"0.28\"/>\n      </linearGradient>\n    </defs>\n    <line x1=\"0\" y1=\"160\" x2=\"1440\" y2=\"160\" stroke=\"rgba(27,58,138,0.15)\" stroke-width=\"1\"/>\n    <line x1=\"0\" y1=\"320\" x2=\"1440\" y2=\"320\" stroke=\"rgba(27,58,138,0.10)\" stroke-width=\"1\"/>\n    <path class=\"w1\" d=\"M0,280 C200,240 400,320 600,280 C800,240 1000,300 1200,260 C1350,230 1400,250 1440,240 L1440,500 L0,500 Z\" fill=\"url(#wg1)\"/>\n    <path class=\"w2\" d=\"M0,340 C220,300 440,380 660,340 C880,300 1060,360 1260,320 C1380,295 1420,310 1440,305 L1440,500 L0,500 Z\" fill=\"url(#wg2)\"/>\n    <path class=\"w3\" d=\"M0,390 C260,355 480,420 720,390 C960,355 1120,405 1340,375 C1400,362 1430,370 1440,368 L1440,500 L0,500 Z\" fill=\"url(#wg3)\"/>\n  </svg>\n  <h1>You're not losing to competitors.<br>You're losing to <em>confusion.</em></h1>\n  <p class=\"hero-sub\">Your product is better. Your team is sharper. But when buyers sit down to decide, they pick the company that explained themselves more clearly.</p>\n  <a href=\"https://ripmediagroup.com/audit\" class=\"hero-cta\">Get Your Free Story Diagnosis</a>\n</div>\n\n<div class=\"stat-bar\">\n  <div class=\"stat-bar-inner\">\n    <div class=\"stat-item fade-in\"><div class=\"stat-num\">$250M+</div><div class=\"stat-desc\">In client revenue generated</div></div>\n    <div class=\"stat-item fade-in\"><div class=\"stat-num\">1,000+</div><div class=\"stat-desc\">Brand campaigns produced</div></div>\n    <div class=\"stat-item fade-in\"><div class=\"stat-num\">100K+</div><div class=\"stat-desc\">Professionals trained on EPIC</div></div>\n    <div class=\"stat-item fade-in\"><div class=\"stat-num\">15 yrs</div><div class=\"stat-desc\">Closing enterprise B2B deals</div></div>\n  </div>\n</div>\n\n<div class=\"section fade-in\">\n  <div class=\"section-label\">The Real Problem</div>\n  <h2>Confusion is not a soft problem.<br>There is a number attached to it.</h2>\n  <p>Take your average deal size. Multiply it by the number of qualified opportunities that went quiet last quarter. Not lost to a competitor. Just gone. That number is what confusion costs you. Every quarter. Without anyone calling it what it is.</p>\n  <div class=\"confusion-grid\">\n    <div class=\"confusion-card fade-in\"><div class=\"card-num\">01</div><div class=\"card-title\">Your story sounds like everyone else's</div><div class=\"card-body\">You lead with features and specs when your buyer needs to feel the problem you solve. Every competitor's website says the same thing yours does.</div></div>\n    <div class=\"confusion-card fade-in\"><div class=\"card-num\">02</div><div class=\"card-title\">Your sales team is winging it</div><div class=\"card-body\">Every rep tells a different story. Nobody can articulate your value in under 60 seconds. Buyers sense the inconsistency and stall.</div></div>\n    <div class=\"confusion-card fade-in\"><div class=\"card-num\">03</div><div class=\"card-title\">Your content does not convert</div><div class=\"card-body\">You are publishing, but nothing moves. Your brand looks like a template, not a category leader. Buyers scroll past it.</div></div>\n    <div class=\"confusion-card fade-in\"><div class=\"card-num\">04</div><div class=\"card-title\">You are doing everything manually</div><div class=\"card-body\">Your competitors are using AI to prospect, personalize, and follow up around the clock. You are still in spreadsheets.</div></div>\n  </div>\n</div>\n\n<div class=\"calc-section\">\n  <div class=\"calc-inner\">\n    <div class=\"calc-label\">Confusion Cost Calculator</div>\n    <h2>What is your story problem costing you?</h2>\n    <p class=\"calc-sub\">Adjust the inputs below. The math is simple. The number usually surprises people.</p>\n    <div class=\"calc-grid\">\n      <div class=\"calc-field\"><label>Average Deal Size ($)</label><input type=\"number\" id=\"dealSize\" value=\"30000\" min=\"1000\" step=\"1000\"></div>\n      <div class=\"calc-field\"><label>Lost Deals Per Quarter</label><input type=\"number\" id=\"lostDeals\" value=\"5\" min=\"1\" step=\"1\"></div>\n      <div class=\"calc-field\"><label>Current Close Rate (%)</label><input type=\"number\" id=\"closeRate\" value=\"20\" min=\"1\" max=\"99\" step=\"1\"></div>\n    </div>\n    <div class=\"calc-results\">\n      <div class=\"result-box fade-in\"><div class=\"result-label\">Lost Per Quarter</div><div class=\"result-num\" id=\"r-quarter\">$150,000</div><div class=\"result-sub\">Revenue walking out the door</div></div>\n      <div class=\"result-box highlight fade-in\"><div class=\"result-label\">Lost Per Year</div><div class=\"result-num\" id=\"r-annual\">$600,000</div><div class=\"result-sub\">What confusion costs annually</div></div>\n      <div class=\"result-box fade-in\"><div class=\"result-label\">If Close Rate +5%</div><div class=\"result-num\" id=\"r-upside\">$30,000</div><div class=\"result-sub\">Annual upside from Story clarity</div></div>\n    </div>\n    <p class=\"calc-note\">* This model uses your inputs to estimate revenue exposure from unclear positioning. It does not account for pipeline velocity, CAC, or deal cycle length.</p>\n  </div>\n</div>\n\n<div class=\"sdi-section\">\n  <div class=\"sdi-inner\">\n    <div class=\"section-label\">Quick SDI Snapshot</div>\n    <h2>How differentiated is your story right now?</h2>\n    <p class=\"sdi-desc\">Answer five questions. Get a directional score. This is not the full Story Differentiation Index — that requires live competitive data — but it will show you where the cracks are.</p>\n    <div class=\"sdi-questions\">\n      <div class=\"sdi-q fade-in\"><div class=\"sdi-q-text\">1. If a buyer reads your website homepage, how clearly does it explain the specific problem you solve?</div><div class=\"sdi-options\"><button class=\"sdi-opt\" data-q=\"1\" data-val=\"1\">Vague or generic</button><button class=\"sdi-opt\" data-q=\"1\" data-val=\"2\">Somewhat clear</button><button class=\"sdi-opt\" data-q=\"1\" data-val=\"3\">Very specific</button></div></div>\n      <div class=\"sdi-q fade-in\"><div class=\"sdi-q-text\">2. Could your top three competitors use your homepage headline without changing a word?</div><div class=\"sdi-options\"><button class=\"sdi-opt\" data-q=\"2\" data-val=\"1\">Yes, easily</button><button class=\"sdi-opt\" data-q=\"2\" data-val=\"2\">Maybe one or two</button><button class=\"sdi-opt\" data-q=\"2\" data-val=\"3\">No, it is unique to us</button></div></div>\n      <div class=\"sdi-q fade-in\"><div class=\"sdi-q-text\">3. When your sales team explains your value, how consistent is the message across reps?</div><div class=\"sdi-options\"><button class=\"sdi-opt\" data-q=\"3\" data-val=\"1\">Every rep says something different</button><button class=\"sdi-opt\" data-q=\"3\" data-val=\"2\">Mostly aligned</button><button class=\"sdi-opt\" data-q=\"3\" data-val=\"3\">Same story every time</button></div></div>\n      <div class=\"sdi-q fade-in\"><div class=\"sdi-q-text\">4. How often do deals stall at the \"we need to think about it\" stage?</div><div class=\"sdi-options\"><button class=\"sdi-opt\" data-q=\"4\" data-val=\"1\">Constantly</button><button class=\"sdi-opt\" data-q=\"4\" data-val=\"2\">Sometimes</button><button class=\"sdi-opt\" data-q=\"4\" data-val=\"3\">Rarely</button></div></div>\n      <div class=\"sdi-q fade-in\"><div class=\"sdi-q-text\">5. Does your sales content lead with the buyer's problem or your product's features?</div><div class=\"sdi-options\"><button class=\"sdi-opt\" data-q=\"5\" data-val=\"1\">Mostly our features</button><button class=\"sdi-opt\" data-q=\"5\" data-val=\"2\">A mix of both</button><button class=\"sdi-opt\" data-q=\"5\" data-val=\"3\">Buyer's problem first</button></div></div>\n    </div>\n    <button class=\"sdi-run-btn\" id=\"sdiRunBtn\" onclick=\"runSDI()\">Get My Snapshot Score</button>\n    <div class=\"sdi-result-panel\" id=\"sdiResult\">\n      <div class=\"sdi-score-display\" id=\"sdiScoreNum\">--</div>\n      <div class=\"sdi-score-label\">Story Differentiation Index &middot; Snapshot Score</div>\n      <div class=\"sdi-verdict\" id=\"sdiVerdict\"></div>\n      <div class=\"sdi-caveat\"><strong>This is a directional snapshot only.</strong> A complete SDI score requires live competitive data, website analysis, and messaging benchmarking against your actual market.<br><br>For a complete score and a line-by-line analysis of where your story is losing buyers, book the free Sales Message Diagnosis.</div>\n      <a href=\"https://ripmediagroup.com/audit\" class=\"sdi-deep-btn\">Get My Full Story Diagnosis</a>\n    </div>\n  </div>\n</div>\n\n<div class=\"proof-section\">\n  <div class=\"proof-inner\">\n    <div class=\"section-label\">Real Results. Real Companies.</div>\n    <h2>None of them had a product problem.<br>Every one had a story problem.</h2>\n    <div class=\"proof-grid\">\n      <div class=\"proof-card fade-in\"><div class=\"proof-company\">Netlinks</div><div class=\"proof-result\"><span>$1M</span> from one presentation</div><div class=\"proof-desc\">One fixed story. One asset. One deal. The story was the only thing that changed.</div></div>\n      <div class=\"proof-card fade-in\"><div class=\"proof-company\">RedFox Metaverse</div><div class=\"proof-result\"><span>$2M</span> in 40 days</div><div class=\"proof-desc\">1.7M views. Story and assets deployed together. The machine ran the pipeline.</div></div>\n      <div class=\"proof-card fade-in\"><div class=\"proof-company\">Motorola</div><div class=\"proof-result\"><span>600%</span> revenue increase</div><div class=\"proof-desc\">Differentiated story across a 1,000% traffic increase. Clarity converts at scale.</div></div>\n      <div class=\"proof-card fade-in\"><div class=\"proof-company\">Novo Biosciences</div><div class=\"proof-result\"><span>$11M</span> in funding secured</div><div class=\"proof-desc\">Investors fund stories they understand. The pitch was rebuilt from the ground up.</div></div>\n      <div class=\"proof-card fade-in\"><div class=\"proof-company\">KnowRe</div><div class=\"proof-result\"><span>$7M+</span> funding raised</div><div class=\"proof-desc\">Combined with Novo: $18M+ across two launch and fundraise engagements.</div></div>\n      <div class=\"proof-card fade-in\"><div class=\"proof-company\">Microduino</div><div class=\"proof-result\"><span>800%</span> ROI</div><div class=\"proof-desc\">Story clarity compounded through assets. Every dollar spent returned eight.</div></div>\n    </div>\n  </div>\n</div>\n\n<div class=\"teaser-section\">\n  <div class=\"teaser-inner\">\n    <div class=\"teaser-eyebrow\">Coming Thursday &middot; Email 2 of 3</div>\n    <h2>Fixing the story is the foundation.<br>The Machine is <em>the multiplier.</em></h2>\n    <p class=\"teaser-body\">In three days, I will show you what happens when you take a clear story and put AI behind it. Pre-call research in under 60 seconds. Personalized outreach at scale. Pipeline from visitors who never filled out a form.</p>\n    <a href=\"https://ripmediagroup.com/audit\" class=\"teaser-cta\">Don't Wait — Book Your Diagnosis Now</a>\n    <div class=\"teaser-timer\">Email 2 arrives Thursday &middot; Limited to 8 diagnoses per month</div>\n  </div>\n</div>\n\n<div class=\"footer\">\n  <div class=\"footer-logo\">Rip Media <span>Group</span> &middot; Maury Rogow</div>\n  <a href=\"https://ripmediagroup.com/audit\" class=\"footer-link\">ripmediagroup.com/audit</a>\n</div>\n\n<script>\nfunction fmt(n) { return '$' + Math.round(n).toLocaleString('en-US'); }\nfunction calcUpdate() {\n  var deal = parseFloat(document.getElementById('dealSize').value) || 30000;\n  var lost = parseFloat(document.getElementById('lostDeals').value) || 5;\n  var rate = parseFloat(document.getElementById('closeRate').value) || 20;\n  var quarterly = deal * lost;\n  var annual = quarterly * 4;\n  var pipelineDeals = lost / (1 - rate / 100);\n  var upside = pipelineDeals * 0.05 * deal * 4;\n  document.getElementById('r-quarter').textContent = fmt(quarterly);\n  document.getElementById('r-annual').textContent = fmt(annual);\n  document.getElementById('r-upside').textContent = fmt(upside);\n}\n['dealSize','lostDeals','closeRate'].forEach(function(id) {\n  document.getElementById(id).addEventListener('input', calcUpdate);\n});\ncalcUpdate();\n\nvar answers = {};\ndocument.querySelectorAll('.sdi-opt').forEach(function(btn) {\n  btn.addEventListener('click', function() {\n    var q = this.dataset.q;\n    answers[q] = parseInt(this.dataset.val);\n    document.querySelectorAll('.sdi-opt[data-q=\"' + q + '\"]').forEach(function(b) { b.classList.remove('selected'); });\n    this.classList.add('selected');\n  });\n});\n\nfunction runSDI() {\n  if (Object.keys(answers).length < 5) { alert('Please answer all five questions to get your snapshot score.'); return; }\n  var total = Object.values(answers).reduce(function(a, b) { return a + b; }, 0);\n  var score = Math.min(100, Math.max(0, Math.round(((total - 5) / 10) * 100)));\n  var verdict = score <= 33 ? 'High Confusion Risk — Buyers cannot tell you apart from your competitors.' : score <= 66 ? 'Moderate Differentiation — Your story is partially working. There are gaps costing you deals.' : 'Strong Story Foundation — You have clarity. The next step is scaling it with Assets and the Machine.';\n  document.getElementById('sdiScoreNum').textContent = score;\n  document.getElementById('sdiVerdict').textContent = verdict;\n  var panel = document.getElementById('sdiResult');\n  panel.classList.add('visible');\n  panel.scrollIntoView({ behavior: 'smooth', block: 'center' });\n}\n\nvar observer = new IntersectionObserver(function(entries) {\n  entries.forEach(function(e) {\n    if (e.isIntersecting) { e.target.classList.add('visible'); observer.unobserve(e.target); }\n  });\n}, { threshold: 0.1 });\ndocument.querySelectorAll('.fade-in').forEach(function(el) { observer.observe(el); });\n</script>"
              },
              "elements": []
            }
          ]
        }
      ]
    }
  ]
}